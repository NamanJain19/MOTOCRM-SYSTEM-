<!-- SaaS Top Navigation Bar -->
<header class="h-16 bg-white border-b border-slate-200/60 dark:bg-brand-darkCard dark:border-brand-darkBorder flex items-center justify-between px-6 shrink-0 z-20 select-none">
  
  <!-- Left Side: Toggle Sidebar & Brand Info -->
  <div class="flex items-center gap-4">
    <!-- Collapsible Menu Toggler -->
    <button 
      id="sidebar-toggle-btn-nav"
      class="p-2 rounded-xl text-slate-500 hover:bg-slate-50 dark:text-zinc-400 dark:hover:bg-brand-darkBg hover:text-slate-900 transition-all cursor-pointer"
      title="Toggle Sidebar Menu"
    >
      <i data-lucide="menu" class="w-5 h-5"></i>
    </button>
    
    <!-- Path Label indicator -->
    <div class="hidden sm:flex items-center gap-2 text-xs font-semibold text-slate-400 dark:text-zinc-550">
      <span>MotoCRM Pro</span>
      <i data-lucide="chevron-right" class="w-3.5 h-3.5"></i>
      <span class="text-slate-800 dark:text-zinc-200 font-bold select-none capitalize">
        <%= title === 'Dashboard' ? 'Overview' : title.replace('Management', '').trim() %>
      </span>
    </div>
  </div>

  <!-- Center Side: Global Search Leads -->
  <div class="flex-1 max-w-md mx-6">
    <form action="/leads" method="GET" class="relative">
      <div class="absolute inset-y-0 left-3.5 flex items-center text-slate-400 pointer-events-none">
        <i data-lucide="search" class="w-4 h-4"></i>
      </div>
      <input 
        type="text" 
        name="search"
        placeholder="Global Search Leads (e.g. John)..."
        value="<%= locals.search || '' %>"
        class="w-full pl-10 pr-4 py-2 bg-slate-50 dark:bg-brand-darkBg border border-slate-200/60 dark:border-brand-darkBorder rounded-xl text-xs placeholder-slate-400 text-slate-800 dark:text-zinc-200 focus:outline-none focus:border-brand-orange transition-all font-medium"
      />
    </form>
  </div>

  <!-- Right Side: Quick Actions & Profile Dropdown -->
  <div class="flex items-center gap-4">
    <!-- Action Icons -->
    <div class="flex items-center gap-3">
      <!-- Notifications -->
      <button
        class="relative w-9 h-9 rounded-xl flex items-center justify-center text-slate-500 dark:text-zinc-450 hover:bg-slate-50 dark:hover:bg-brand-darkBg transition-all cursor-pointer"
        title="Notifications"
        onclick="showNotifications(event)"
      >
        <i data-lucide="bell" class="w-4.5 h-4.5"></i>
        <span id="notification-bell-dot" class="absolute top-2 right-2 w-2.5 h-2.5 bg-brand-orange rounded-full border border-white dark:border-zinc-800 animate-pulse hidden"></span>
      </button>

      <!-- Theme Toggle - Light -->
      <button
        id="theme-btn-light"
        onclick="updateTheme('light')"
        class="w-9 h-9 rounded-xl flex items-center justify-center text-slate-500 dark:text-zinc-450 hover:bg-slate-50 dark:hover:bg-brand-darkBg transition-all cursor-pointer"
        title="Light Mode"
      >
        <i data-lucide="sun" class="w-4.5 h-4.5"></i>
      </button>

      <!-- Theme Toggle - Dark -->
      <button
        id="theme-btn-dark"
        onclick="updateTheme('dark')"
        class="w-9 h-9 rounded-xl flex items-center justify-center text-slate-500 dark:text-zinc-450 hover:bg-slate-50 dark:hover:bg-brand-darkBg transition-all cursor-pointer"
        title="Dark Mode"
      >
        <i data-lucide="moon" class="w-4.5 h-4.5"></i>
      </button>

      <!-- System Info -->
      <button
        class="w-9 h-9 rounded-xl flex items-center justify-center text-slate-500 dark:text-zinc-450 hover:bg-slate-50 dark:hover:bg-brand-darkBg transition-all cursor-pointer"
        title="System Info"
        onclick="showSystemInfo(event)"
      >
        <i data-lucide="info" class="w-4.5 h-4.5"></i>
      </button>
    </div>

    <!-- User Profile Dropdown slot -->
    <div class="relative border-l border-slate-200/60 dark:border-brand-darkBorder pl-4">
      <button 
        id="profile-dropdown-btn" 
        class="flex items-center gap-2.5 p-1 rounded-xl hover:bg-slate-50 dark:hover:bg-brand-darkBg transition-all cursor-pointer"
        title="Account Profile"
      >
        <% if (locals.user && locals.user.avatar) { %>
          <img src="<%= locals.user.avatar %>" alt="Avatar" class="w-8 h-8 rounded-full object-cover shrink-0 shadow-sm" />
        <% } else { %>
          <div class="w-8 h-8 rounded-full bg-slate-900 text-white dark:bg-brand-orange font-bold text-xs flex items-center justify-center shrink-0 shadow-sm">
            <%= locals.user ? locals.user.name.split(' ').map(n => n[0]).join('').toUpperCase().substring(0, 2) : 'U' %>
          </div>
        <% } %>
        <div class="hidden lg:block leading-tight text-left">
          <h4 class="font-bold text-xs text-slate-800 dark:text-zinc-200"><%= locals.user ? locals.user.name : 'User' %></h4>
          <span class="text-[9px] text-slate-450 dark:text-zinc-550 block font-semibold"><%= locals.user ? locals.user.role : 'Member' %></span>
        </div>
        <i data-lucide="chevron-down" class="w-3.5 h-3.5 text-slate-400"></i>
      </button>

      <!-- Dropdown Menu Box -->
      <div 
        id="profile-dropdown-menu" 
        class="hidden absolute top-12 right-0 w-56 bg-white dark:bg-brand-darkCard border border-slate-200/60 dark:border-brand-darkBorder rounded-2xl shadow-lg p-2.5 z-50 animate-in fade-in slide-in-from-top-2 duration-150"
      >
        <div class="px-3 py-2 border-b border-slate-100 dark:border-brand-darkBorder mb-1">
          <h4 class="font-extrabold text-xs text-slate-850 dark:text-white"><%= locals.user ? locals.user.name : 'User' %></h4>
          <span class="text-[10px] text-slate-400 dark:text-zinc-500 font-semibold block truncate"><%= locals.user ? locals.user.email : '' %></span>
        </div>
        <div class="py-1 space-y-0.5">
          <a href="/settings" class="flex items-center gap-2.5 px-3 py-2 rounded-xl text-xs font-semibold text-slate-650 hover:bg-slate-50 dark:text-zinc-400 dark:hover:bg-brand-darkBg dark:hover:text-zinc-250 transition-all">
            <i data-lucide="user" class="w-4 h-4 text-slate-400 shrink-0"></i>
            <span>My Profile</span>
          </a>
          <a href="/settings" class="flex items-center gap-2.5 px-3 py-2 rounded-xl text-xs font-semibold text-slate-650 hover:bg-slate-50 dark:text-zinc-400 dark:hover:bg-brand-darkBg dark:hover:text-zinc-250 transition-all">
            <i data-lucide="settings" class="w-4 h-4 text-slate-400 shrink-0"></i>
            <span>System Settings</span>
          </a>
        </div>
        <div class="border-t border-slate-100 dark:border-brand-darkBorder pt-1.5 mt-1">
          <button 
            onclick="handleLogout()" 
            class="w-full flex items-center gap-2.5 px-3 py-2 rounded-xl text-xs font-bold text-rose-550 hover:bg-rose-50 dark:hover:bg-rose-950/20 transition-all cursor-pointer"
          >
            <i data-lucide="log-out" class="w-4 h-4 shrink-0"></i>
            <span>Log Out</span>
          </button>
        </div>
      </div>
    </div>
  </div>

</header>
