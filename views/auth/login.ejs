<!DOCTYPE html>
<html lang="en" class="light">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - MotoCRM Pro</title>
  
  <!-- Plus Jakarta Sans Font -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  
  <!-- Tailwind CSS CDN -->
  <script src="https://cdn.tailwindcss.com"></script>
  
  <!-- Tailwind Configuration -->
  <script>
    tailwind.config = {
      darkMode: 'class',
      theme: {
        extend: {
          fontFamily: {
            sans: ['"Plus Jakarta Sans"', 'sans-serif'],
          },
          colors: {
            brand: {
              blue: '#0b57d0',
              hoverBlue: '#0a4eb8',
              orange: '#ff5c35',
              lightBg: '#f4f6fa',
              darkBg: '#0e0e10',
              darkCard: '#161619',
              darkBorder: '#242427',
              accentBlue: '#0052cc',
              accentYellow: '#f5a623',
              accentGreen: '#10b981',
              accentRed: '#ef4444'
            }
          }
        }
      }
    }
  </script>
  
  <script src="https://unpkg.com/lucide@latest"></script>
  
  <!-- Initialize theme immediately to prevent flashing -->
  <script>
    (function() {
      const theme = localStorage.getItem('motocrm-theme') || 'dark';
      const root = document.documentElement;
      if (theme === 'dark') {
        root.classList.add('dark');
      } else {
        root.classList.remove('dark');
      }
    })();
  </script>
</head>
<body class="bg-brand-lightBg text-slate-800 dark:bg-brand-darkBg dark:text-zinc-100 min-h-screen flex items-center justify-center p-6 font-sans transition-colors duration-250">

  <!-- Floating Theme Switcher -->
  <div class="fixed top-6 right-6 flex items-center gap-2 z-50">
    <button 
      id="theme-toggle-btn"
      class="w-9 h-9 rounded-xl border border-slate-200/60 dark:border-brand-darkBorder bg-white dark:bg-brand-darkCard text-slate-500 dark:text-zinc-400 hover:bg-slate-50 dark:hover:bg-brand-darkBg transition-all flex items-center justify-center cursor-pointer shadow-sm"
      title="Toggle Dark/Light Mode"
    >
      <!-- Sun icon shows in dark mode -->
      <i data-lucide="sun" class="w-4.5 h-4.5 hidden dark:block text-brand-orange"></i>
      <!-- Moon icon shows in light mode -->
      <i data-lucide="moon" class="w-4.5 h-4.5 block dark:hidden text-slate-650"></i>
    </button>
  </div>

  <div class="w-full max-w-md">
    <!-- Logo Section -->
    <div class="text-center mb-8 select-none">
      <div class="w-12 h-12 rounded-2xl bg-brand-orange flex items-center justify-center text-white shadow-md shadow-orange-500/10 mx-auto mb-4">
        <i data-lucide="bike" class="w-6 h-6"></i>
      </div>
      <h1 class="text-2xl font-extrabold tracking-tight text-slate-900 dark:text-white">
        Moto<span class="text-brand-orange">CRM</span><span class="text-[10px] font-bold text-slate-455 bg-slate-100 dark:bg-brand-darkCard dark:text-zinc-500 ml-1 px-1.5 py-0.5 rounded-md uppercase">Pro</span>
      </h1>
      <p class="text-xs text-slate-500 dark:text-zinc-400 mt-2 font-medium">Dealership Management & Acquisition System</p>
    </div>

    <!-- Login Card -->
    <div class="bg-white dark:bg-brand-darkCard border border-slate-200/60 dark:border-brand-darkBorder rounded-3xl shadow-xl p-8 relative overflow-hidden">
      <h2 class="text-xl font-extrabold text-slate-900 dark:text-white mb-6">Welcome Back</h2>

      <!-- Error Message -->
      <div id="error-message" class="<%= (typeof errorMessage !== 'undefined' && errorMessage) ? 'flex' : 'hidden' %> mb-5 p-4 bg-rose-50 dark:bg-rose-950/20 border border-rose-200/50 dark:border-rose-900/50 rounded-2xl text-rose-700 dark:text-rose-450 text-xs font-bold items-center gap-2">
        <i data-lucide="alert-triangle" class="w-4 h-4 shrink-0 text-rose-500"></i>
        <span class="flex-1"><%= (typeof errorMessage !== 'undefined' && errorMessage) ? errorMessage : '' %></span>
      </div>

      <!-- Success Message -->
      <div id="success-message" class="hidden mb-5 p-4 bg-emerald-50 dark:bg-emerald-950/20 border border-emerald-250/50 dark:border-emerald-900/50 rounded-2xl text-emerald-700 dark:text-emerald-450 text-xs font-bold items-center gap-2">
        <i data-lucide="check-circle-2" class="w-4 h-4 shrink-0 text-emerald-500"></i>
        <span class="flex-1"></span>
      </div>

      <!-- Login Form -->
      <form id="login-form" class="space-y-5">
        <!-- Email -->
        <div>
          <label class="text-[10px] font-extrabold text-slate-400 dark:text-zinc-500 uppercase tracking-wider mb-2 block">Email Address</label>
          <div class="relative">
            <div class="absolute inset-y-0 left-4 flex items-center text-slate-400 pointer-events-none">
              <i data-lucide="mail" class="w-4 h-4"></i>
            </div>
            <input 
              type="email" 
              id="email" 
              name="email" 
              placeholder="Enter your email" 
              class="w-full pl-11 pr-4 py-2.5 bg-slate-50 dark:bg-brand-darkBg border border-slate-200 dark:border-brand-darkBorder rounded-xl text-sm text-slate-800 dark:text-zinc-200 focus:outline-none focus:border-brand-orange focus:ring-1 focus:ring-brand-orange transition-all font-semibold"
              required
            >
          </div>
        </div>

        <!-- Password -->
        <div>
          <div class="flex justify-between items-center mb-2">
            <label class="text-[10px] font-extrabold text-slate-400 dark:text-zinc-500 uppercase tracking-wider block">Password</label>
            <a href="/auth/forgot-password" class="text-[10px] font-bold text-brand-orange hover:underline transition-all">Forgot Password?</a>
          </div>
          <div class="relative">
            <div class="absolute inset-y-0 left-4 flex items-center text-slate-400 pointer-events-none">
              <i data-lucide="lock" class="w-4 h-4"></i>
            </div>
            <input 
              type="password" 
              id="password" 
              name="password" 
              placeholder="Enter your password" 
              class="w-full pl-11 pr-4 py-2.5 bg-slate-50 dark:bg-brand-darkBg border border-slate-200 dark:border-brand-darkBorder rounded-xl text-sm text-slate-800 dark:text-zinc-200 focus:outline-none focus:border-brand-orange focus:ring-1 focus:ring-brand-orange transition-all font-semibold"
              required
            >
          </div>
        </div>

        <!-- Remember Me -->
        <div class="flex items-center">
          <input 
            type="checkbox" 
            id="remember" 
            class="w-4 h-4 rounded border-slate-350 dark:border-brand-darkBorder dark:bg-brand-darkBg text-brand-orange focus:ring-brand-orange focus:ring-offset-0 cursor-pointer"
          >
          <label for="remember" class="ml-2 text-xs font-semibold text-slate-550 dark:text-zinc-400 select-none cursor-pointer">Remember my credentials</label>
        </div>

        <!-- Login Button -->
        <button 
          type="submit" 
          id="login-submit-btn"
          class="w-full bg-brand-orange hover:bg-orange-600 text-white font-bold text-xs py-3.5 px-4 rounded-2xl transition-all shadow-md flex items-center justify-center gap-2 cursor-pointer"
        >
          <i data-lucide="log-in" class="w-4.5 h-4.5"></i>
          <span id="btn-text">Sign In to Dashboard</span>
        </button>

        <% if (typeof googleLoginEnabled !== 'undefined' && googleLoginEnabled) { %>
        <!-- Divider -->
        <div class="relative my-4 flex items-center justify-center">
          <div class="absolute inset-0 flex items-center">
            <div class="w-full border-t border-slate-100 dark:border-brand-darkBorder"></div>
          </div>
          <span class="relative bg-white dark:bg-brand-darkCard px-3.5 text-[9px] font-extrabold uppercase tracking-widest text-slate-400 dark:text-zinc-550">Or</span>
        </div>

        <!-- Google OAuth Button -->
        <a 
          href="/auth/google" 
          class="w-full border border-slate-200 dark:border-brand-darkBorder hover:bg-slate-50 dark:hover:bg-brand-darkBg text-slate-700 dark:text-zinc-350 font-bold text-xs py-3 px-4 rounded-2xl transition-all flex items-center justify-center gap-2.5 cursor-pointer"
        >
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.06H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.94l2.85-2.22.81-.63z" fill="#FBBC05"/>
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.06l3.66 2.84c.87-2.6 3.3-4.52 6.16-4.52z" fill="#EA4335"/>
          </svg>
          <span>Continue with Google</span>
        </a>
        <% } %>
      </form>

      <!-- Register Link -->
      <div class="mt-6 text-center border-t border-slate-100 dark:border-brand-darkBorder pt-5">
        <p class="text-slate-500 dark:text-zinc-400 text-xs font-semibold">
          Don't have a credential account? 
          <a href="/auth/register" class="text-brand-orange font-bold hover:underline transition-all">Sign up here</a>
        </p>
      </div>

    </div>
  </div>

  <!-- Script for Theme Toggle & Dynamic Form Submission -->
  <script>
    lucide.createIcons();

    // Theme switcher logic
    const themeToggleBtn = document.getElementById('theme-toggle-btn');
    if (themeToggleBtn) {
      themeToggleBtn.addEventListener('click', () => {
        const root = document.documentElement;
        if (root.classList.contains('dark')) {
          root.classList.remove('dark');
          localStorage.setItem('motocrm-theme', 'light');
        } else {
          root.classList.add('dark');
          localStorage.setItem('motocrm-theme', 'dark');
        }
      });
    }

    // Pre-populate Remember Me email
    document.addEventListener('DOMContentLoaded', () => {
      const savedEmail = localStorage.getItem('motocrm-remembered-email');
      const rememberCheckbox = document.getElementById('remember');
      if (savedEmail) {
        document.getElementById('email').value = savedEmail;
        if (rememberCheckbox) rememberCheckbox.checked = true;
      }
    });

    // Handle form submission
    document.getElementById('login-form').addEventListener('submit', async (e) => {
      e.preventDefault();

      const email = document.getElementById('email').value;
      const password = document.getElementById('password').value;
      const rememberChecked = document.getElementById('remember').checked;

      const errorDiv = document.getElementById('error-message');
      const successDiv = document.getElementById('success-message');
      const submitBtn = document.getElementById('login-submit-btn');
      const btnText = document.getElementById('btn-text');
      
      errorDiv.classList.add('hidden');
      errorDiv.classList.remove('flex');
      successDiv.classList.add('hidden');
      successDiv.classList.remove('flex');

      // Set loading state immediately on first click to prevent double clicks/freezes
      submitBtn.disabled = true;
      btnText.textContent = 'Signing In...';

      try {
        const response = await fetch('/auth/login', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({ email, password })
        });

        const data = await response.json();

        if (response.ok && data.success) {
          // Manage Remember Me preference
          if (rememberChecked) {
            localStorage.setItem('motocrm-remembered-email', email);
          } else {
            localStorage.removeItem('motocrm-remembered-email');
          }

          // Immediate redirect without delay
          window.location.href = data.redirect || '/';
        } else {
          errorDiv.lastElementChild.textContent = data.error || 'Login failed. Please verify credentials.';
          errorDiv.classList.remove('hidden');
          errorDiv.classList.add('flex');
          
          // Restore button
          submitBtn.disabled = false;
          btnText.textContent = 'Sign In to Dashboard';
        }
      } catch (error) {
        console.error('Login error:', error);
        errorDiv.lastElementChild.textContent = 'A connection error occurred. Please try again.';
        errorDiv.classList.remove('hidden');
        errorDiv.classList.add('flex');
        
        // Restore button
        submitBtn.disabled = false;
        btnText.textContent = 'Sign In to Dashboard';
      }
    });
  </script>
</body>
</html>
