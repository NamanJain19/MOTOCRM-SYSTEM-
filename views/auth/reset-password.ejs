<!DOCTYPE html>
<html lang="en" class="light">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  
  <!-- Plus Jakarta Sans Font -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  
  <!-- Tailwind CSS CDN -->
  <script src="https://cdn.tailwindcss.com"></script>
  
  <!-- Tailwind Configuration -->
  <script>
    tailwind.config = {
      darkMode: 'class',
      theme: {
        extend: {
          fontFamily: {
            sans: ['"Plus Jakarta Sans"', 'sans-serif'],
          },
          colors: {
            brand: {
              blue: '#0b57d0',
              hoverBlue: '#0a4eb8',
              orange: '#ff5c35',
              lightBg: '#f4f6fa',
              darkBg: '#0e0e10',
              darkCard: '#161619',
              darkBorder: '#242427',
              accentBlue: '#0052cc',
              accentYellow: '#f5a623',
              accentGreen: '#10b981',
              accentRed: '#ef4444'
            }
          }
        }
      }
    }
  </script>
  
  <script src="https://unpkg.com/lucide@latest"></script>
  
  <!-- Initialize theme immediately to prevent flashing -->
  <script>
    (function() {
      const theme = localStorage.getItem('motocrm-theme') || 'dark';
      const root = document.documentElement;
      if (theme === 'dark') {
        root.classList.add('dark');
      } else {
        root.classList.remove('dark');
      }
    })();
  </script>
</head>
<body class="bg-brand-lightBg text-slate-800 dark:bg-brand-darkBg dark:text-zinc-100 min-h-screen flex items-center justify-center p-6 font-sans transition-colors duration-250">

  <!-- Floating Theme Switcher -->
  <div class="fixed top-6 right-6 flex items-center gap-2 z-50">
    <button 
      id="theme-toggle-btn"
      class="w-9 h-9 rounded-xl border border-slate-200/60 dark:border-brand-darkBorder bg-white dark:bg-brand-darkCard text-slate-500 dark:text-zinc-400 hover:bg-slate-50 dark:hover:bg-brand-darkBg transition-all flex items-center justify-center cursor-pointer shadow-sm"
      title="Toggle Dark/Light Mode"
    >
      <i data-lucide="sun" class="w-4.5 h-4.5 hidden dark:block text-brand-orange"></i>
      <i data-lucide="moon" class="w-4.5 h-4.5 block dark:hidden text-slate-650"></i>
    </button>
  </div>

  <div class="w-full max-w-md">
    <!-- Logo Section -->
    <div class="text-center mb-8 select-none">
      <div class="w-12 h-12 rounded-2xl bg-brand-orange flex items-center justify-center text-white shadow-md shadow-orange-500/10 mx-auto mb-4">
        <i data-lucide="bike" class="w-6 h-6"></i>
      </div>
      <h1 class="text-2xl font-extrabold tracking-tight text-slate-900 dark:text-white">
        Moto<span class="text-brand-orange">CRM</span><span class="text-[10px] font-bold text-slate-455 bg-slate-100 dark:bg-brand-darkCard dark:text-zinc-500 ml-1 px-1.5 py-0.5 rounded-md uppercase">Pro</span>
      </h1>
      <p class="text-xs text-slate-500 dark:text-zinc-400 mt-2 font-medium">Reset your dealer credentials securely</p>
    </div>

    <!-- Card Container -->
    <div class="bg-white dark:bg-brand-darkCard border border-slate-200/60 dark:border-brand-darkBorder rounded-3xl shadow-xl p-8 relative overflow-hidden">
      <h2 class="text-xl font-extrabold text-slate-900 dark:text-white mb-6">Choose New Password</h2>

      <% if (error) { %>
        <!-- Immediate Token Error State -->
        <div class="mb-5 p-4 bg-rose-50 dark:bg-rose-955/20 border border-rose-250 dark:border-rose-900/50 rounded-2xl text-rose-700 dark:text-rose-455 text-xs font-bold flex items-center gap-2">
          <i data-lucide="alert-triangle" class="w-4.5 h-4.5 shrink-0 text-rose-500"></i>
          <span class="flex-1"><%= error %></span>
        </div>
        <a href="/auth/forgot-password" class="w-full text-center inline-block px-4 py-2.5 text-xs font-bold text-white bg-brand-orange hover:bg-orange-600 rounded-xl shadow-sm transition-colors">Request New Reset Link &rarr;</a>
      <% } else { %>
        <!-- Messages -->
        <div id="error-message" class="hidden mb-5 p-4 bg-rose-50 dark:bg-rose-955/20 border border-rose-250 dark:border-rose-900/50 rounded-2xl text-rose-700 dark:text-rose-450 text-xs font-bold items-center gap-2">
          <i data-lucide="alert-triangle" class="w-4.5 h-4.5 shrink-0 text-rose-500"></i>
          <span class="flex-1"></span>
        </div>

        <div id="success-message" class="hidden mb-5 p-4 bg-emerald-50 dark:bg-emerald-955/20 border border-emerald-250 dark:border-emerald-900/50 rounded-2xl text-emerald-700 dark:text-emerald-450 text-xs font-bold items-center gap-2">
          <i data-lucide="check-circle-2" class="w-4.5 h-4.5 shrink-0 text-emerald-500"></i>
          <span class="flex-1"></span>
        </div>

        <!-- Reset Form -->
        <form id="reset-form" class="space-y-5">
          <!-- Password -->
          <div>
            <label class="text-[10px] font-extrabold text-slate-400 dark:text-zinc-500 uppercase tracking-wider mb-2 block">New Password</label>
            <div class="relative">
              <div class="absolute inset-y-0 left-4 flex items-center text-slate-400 pointer-events-none">
                <i data-lucide="lock" class="w-4 h-4"></i>
              </div>
              <input 
                type="password" 
                id="password" 
                name="password" 
                placeholder="Minimum 6 characters" 
                class="w-full pl-11 pr-4 py-2.5 bg-slate-50 dark:bg-brand-darkBg border border-slate-200 dark:border-brand-darkBorder rounded-xl text-sm text-slate-800 dark:text-zinc-200 focus:outline-none focus:border-brand-orange focus:ring-1 focus:ring-brand-orange transition-all font-semibold"
                required
                minlength="6"
              >
            </div>
          </div>

          <!-- Confirm Password -->
          <div>
            <label class="text-[10px] font-extrabold text-slate-400 dark:text-zinc-500 uppercase tracking-wider mb-2 block">Confirm Password</label>
            <div class="relative">
              <div class="absolute inset-y-0 left-4 flex items-center text-slate-400 pointer-events-none">
                <i data-lucide="lock-keyhole" class="w-4 h-4"></i>
              </div>
              <input 
                type="password" 
                id="confirmPassword" 
                name="confirmPassword" 
                placeholder="Re-enter your new password" 
                class="w-full pl-11 pr-4 py-2.5 bg-slate-50 dark:bg-brand-darkBg border border-slate-200 dark:border-brand-darkBorder rounded-xl text-sm text-slate-800 dark:text-zinc-200 focus:outline-none focus:border-brand-orange focus:ring-1 focus:ring-brand-orange transition-all font-semibold"
                required
                minlength="6"
              >
            </div>
          </div>

          <button 
            type="submit" 
            id="submit-btn"
            class="w-full bg-brand-orange hover:bg-orange-600 text-white font-bold text-xs py-3.5 px-4 rounded-2xl transition-all shadow-md flex items-center justify-center gap-2 cursor-pointer"
          >
            <i data-lucide="key" class="w-4.5 h-4.5"></i>
            <span id="btn-text">Reset Password</span>
          </button>
        </form>
      <% } %>

      <!-- Back to Login Link -->
      <div class="mt-6 text-center border-t border-slate-100 dark:border-brand-darkBorder pt-5">
        <a href="/auth/login" class="text-xs font-bold text-slate-500 hover:text-brand-orange dark:text-zinc-400 dark:hover:text-white flex items-center justify-center gap-1.5 transition-all">
          <i data-lucide="arrow-left" class="w-4 h-4"></i>
          <span>Back to Sign In</span>
        </a>
      </div>
    </div>
  </div>

  <script>
    lucide.createIcons();

    // Theme toggler
    const themeToggleBtn = document.getElementById('theme-toggle-btn');
    if (themeToggleBtn) {
      themeToggleBtn.addEventListener('click', () => {
        const root = document.documentElement;
        if (root.classList.contains('dark')) {
          root.classList.remove('dark');
          localStorage.setItem('motocrm-theme', 'light');
        } else {
          root.classList.add('dark');
          localStorage.setItem('motocrm-theme', 'dark');
        }
      });
    }

    <% if (!error) { %>
    // Form submission
    document.getElementById('reset-form').addEventListener('submit', async (e) => {
      e.preventDefault();

      const password = document.getElementById('password').value;
      const confirmPassword = document.getElementById('confirmPassword').value;
      
      const errorDiv = document.getElementById('error-message');
      const successDiv = document.getElementById('success-message');
      const submitBtn = document.getElementById('submit-btn');
      const btnText = document.getElementById('btn-text');

      errorDiv.classList.add('hidden');
      successDiv.classList.add('hidden');

      if (password !== confirmPassword) {
        errorDiv.querySelector('span').textContent = 'Passwords do not match!';
        errorDiv.classList.remove('hidden');
        return;
      }

      submitBtn.disabled = true;
      btnText.textContent = 'Updating Password...';

      try {
        const res = await fetch(window.location.pathname, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ password })
        });
        const data = await res.json();

        if (res.ok && data.success) {
          successDiv.querySelector('span').textContent = data.message;
          successDiv.classList.remove('hidden');
          submitBtn.classList.add('hidden');
          
          setTimeout(() => {
            window.location.href = '/auth/login';
          }, 2000);
        } else {
          errorDiv.querySelector('span').textContent = data.error || 'Password reset failed.';
          errorDiv.classList.remove('hidden');
          submitBtn.disabled = false;
          btnText.textContent = 'Reset Password';
        }
      } catch (err) {
        console.error(err);
        errorDiv.querySelector('span').textContent = 'Connection error. Please try again.';
        errorDiv.classList.remove('hidden');
        submitBtn.disabled = false;
        btnText.textContent = 'Reset Password';
      }
    });
    <% } %>
  </script>
</body>
</html>
