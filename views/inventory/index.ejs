<%- include('../partials/head') %>

<!-- Narrow Sidebar -->
<%- include('../partials/sidebar') %>

<!-- Main Wrapper -->
<div class="flex-1 flex flex-col min-w-0 transition-colors duration-200">
  <!-- Header -->
  <%- include('../partials/header') %>

  <!-- Content Container -->
  <main class="flex-1 overflow-y-auto p-8 space-y-6 bg-brand-lightBg dark:bg-brand-darkBg">
    
    <!-- Page Header -->
    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 border-b border-slate-200/60 dark:border-brand-darkBorder pb-5">
      <div>
        <h1 class="text-3xl font-extrabold text-slate-900 dark:text-white tracking-tight">Inventory Management</h1>
        <p class="text-sm text-slate-500 dark:text-zinc-400 mt-1">Track bike models, stock quantities, reservations, and low stock thresholds.</p>
      </div>
    </div>

    <!-- Error Alert if present -->
    <% if (error) { %>
      <div class="bg-rose-50 dark:bg-rose-950/20 border border-rose-200 dark:border-rose-900/50 rounded-2xl p-4 flex items-center gap-3 text-rose-700 dark:text-rose-400 text-sm">
        <i data-lucide="alert-circle" class="w-5 h-5 shrink-0"></i>
        <span><%= error %></span>
      </div>
    <% } %>

    <!-- Low Stock Alert Banner -->
    <% 
      const lowStockItems = inventoryItems.filter(item => item.stockQuantity <= item.lowStockThreshold);
      if (lowStockItems.length > 0) { 
    %>
      <div class="bg-amber-50 dark:bg-amber-950/20 border border-amber-250 dark:border-amber-900/50 rounded-2xl p-4 space-y-2">
        <div class="flex items-center gap-2.5 text-amber-800 dark:text-amber-400 font-bold text-sm">
          <i data-lucide="alert-triangle" class="w-5 h-5 text-amber-600"></i>
          <span>Low Stock Notifications</span>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-3">
          <% lowStockItems.forEach(item => { %>
            <div class="bg-white dark:bg-brand-darkCard border border-amber-100 dark:border-brand-darkBorder p-3 rounded-xl flex justify-between items-center text-xs shadow-sm">
              <div>
                <span class="font-extrabold text-slate-800 dark:text-zinc-200"><%= item.bikeModel %></span>
                <p class="text-[10px] text-slate-400 mt-0.5">Threshold: <%= item.lowStockThreshold %> units</p>
              </div>
              <span class="px-2 py-0.5 bg-rose-50 text-rose-600 dark:bg-rose-950/40 dark:text-rose-400 rounded-full font-bold text-[10px]">
                <%= item.stockQuantity %> Left
              </span>
            </div>
          <% }) %>
        </div>
      </div>
    <% } %>

    <!-- Inventory Summary Stats Row -->
    <div class="grid grid-cols-2 lg:grid-cols-5 gap-6">
      
      <!-- Card 1: Total Models -->
      <div class="bg-white dark:bg-brand-darkCard border border-slate-200/60 dark:border-brand-darkBorder rounded-3xl p-5 shadow-sm">
        <span class="text-[10px] font-extrabold text-slate-400 dark:text-zinc-500 uppercase tracking-wider block">Total Models</span>
        <div class="mt-2 flex items-baseline gap-2">
          <span class="text-2xl font-extrabold text-slate-900 dark:text-white"><%= stats.totalModels %></span>
          <span class="text-[10px] text-slate-400">tracked</span>
        </div>
      </div>

      <!-- Card 2: Total Stock -->
      <div class="bg-white dark:bg-brand-darkCard border border-slate-200/60 dark:border-brand-darkBorder rounded-3xl p-5 shadow-sm">
        <span class="text-[10px] font-extrabold text-slate-400 dark:text-zinc-500 uppercase tracking-wider block">Total Available</span>
        <div class="mt-2 flex items-baseline gap-2">
          <span class="text-2xl font-extrabold text-slate-900 dark:text-white"><%= stats.totalStock %></span>
          <span class="text-[10px] text-slate-400">units</span>
        </div>
      </div>

      <!-- Card 3: Reserved Units -->
      <div class="bg-white dark:bg-brand-darkCard border border-slate-200/60 dark:border-brand-darkBorder rounded-3xl p-5 shadow-sm">
        <span class="text-[10px] font-extrabold text-slate-400 dark:text-zinc-500 uppercase tracking-wider block">Reserved Deals</span>
        <div class="mt-2 flex items-baseline gap-2">
          <span class="text-2xl font-extrabold text-slate-900 dark:text-white"><%= stats.totalReserved %></span>
          <span class="text-[10px] text-slate-400">held</span>
        </div>
      </div>

      <!-- Card 4: Sold Units -->
      <div class="bg-white dark:bg-brand-darkCard border border-slate-200/60 dark:border-brand-darkBorder rounded-3xl p-5 shadow-sm">
        <span class="text-[10px] font-extrabold text-slate-400 dark:text-zinc-500 uppercase tracking-wider block">Total Delivered</span>
        <div class="mt-2 flex items-baseline gap-2">
          <span class="text-2xl font-extrabold text-emerald-600 dark:text-emerald-400"><%= stats.totalSold %></span>
          <span class="text-[10px] text-slate-400">sold</span>
        </div>
      </div>

      <!-- Card 5: Low Stock Items -->
      <div class="bg-white dark:bg-brand-darkCard border border-slate-200/60 dark:border-brand-darkBorder rounded-3xl p-5 shadow-sm col-span-2 lg:col-span-1">
        <span class="text-[10px] font-extrabold text-slate-400 dark:text-zinc-500 uppercase tracking-wider block">Low Stock Alert</span>
        <div class="mt-2 flex items-baseline gap-2">
          <span class="text-2xl font-extrabold <%= stats.lowStockCount > 0 ? 'text-amber-500' : 'text-slate-400' %>"><%= stats.lowStockCount %></span>
          <span class="text-[10px] text-slate-400">items warning</span>
        </div>
      </div>

    </div>

    <!-- Main Table and Creation Forms Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      
      <!-- Left Column: Table List (2/3 width) -->
      <div class="lg:col-span-2 space-y-6">
        <div class="bg-white dark:bg-brand-darkCard border border-slate-200/60 dark:border-brand-darkBorder rounded-3xl shadow-sm overflow-hidden">
          <div class="px-6 py-4 border-b border-slate-100 dark:border-brand-darkBorder flex justify-between items-center bg-slate-50/50 dark:bg-brand-darkBg/50">
            <h3 class="font-bold text-base text-slate-900 dark:text-white">Bike Ledger</h3>
          </div>

          <div class="overflow-x-auto">
            <table class="w-full border-collapse text-left text-xs">
              <thead>
                <tr class="bg-slate-50/50 dark:bg-brand-darkBg/50 border-b border-slate-200 dark:border-brand-darkBorder text-[9px] font-extrabold text-slate-400 dark:text-zinc-500 uppercase tracking-wider">
                  <th class="py-4 px-6">Bike Model</th>
                  <th class="py-4 px-4 text-center">Stock</th>
                  <th class="py-4 px-4 text-center">Reserved</th>
                  <th class="py-4 px-4 text-center">Sold</th>
                  <th class="py-4 px-4">Status</th>
                  <th class="py-4 px-6 text-right">Actions</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100 dark:divide-brand-darkBorder text-slate-700 dark:text-zinc-300 font-medium">
                <% if (inventoryItems.length === 0) { %>
                  <tr>
                    <td colspan="6" class="py-8 text-center text-slate-400 dark:text-zinc-500">
                      <i data-lucide="package-open" class="w-8 h-8 mx-auto mb-2 opacity-55 text-slate-350"></i>
                      No inventory records found. Add models on the right side.
                    </td>
                  </tr>
                <% } else { %>
                  <% inventoryItems.forEach(item => { %>
                    <tr class="hover:bg-slate-50/20 dark:hover:bg-brand-darkBg/20">
                      <td class="py-4 px-6">
                        <div class="font-extrabold text-slate-800 dark:text-zinc-150"><%= item.bikeModel %></div>
                        <div class="text-[10px] text-slate-400 mt-1 flex items-center gap-1.5 flex-wrap">
                          <% if (item.colors && item.colors.length > 0) { %>
                            <% item.colors.forEach((c, idx) => { %>
                              <span><%= c %></span>
                              <% if (idx < item.colors.length - 1) { %>
                                <span class="text-slate-300 dark:text-zinc-650">•</span>
                              <% } %>
                            <% }) %>
                          <% } else { %>
                            <span class="italic text-slate-400">No colors</span>
                          <% } %>
                        </div>
                      </td>
                      <td class="py-4 px-4 text-center font-bold text-slate-900 dark:text-white"><%= item.stockQuantity %></td>
                      <td class="py-4 px-4 text-center text-slate-500"><%= item.reservedBikes %></td>
                      <td class="py-4 px-4 text-center text-emerald-600 dark:text-emerald-400"><%= item.soldBikes %></td>
                      <td class="py-4 px-4">
                        <% if (item.status === 'Inactive') { %>
                          <span class="inline-flex items-center gap-1 bg-slate-100 text-slate-500 dark:bg-zinc-800 dark:text-zinc-400 px-2.5 py-1 rounded-full text-[10px] font-bold border border-slate-200 dark:border-zinc-700">
                            <span class="w-1.5 h-1.5 rounded-full bg-slate-400"></span>Inactive
                          </span>
                        <% } else { %>
                          <span class="inline-flex items-center gap-1 bg-emerald-50 text-emerald-600 dark:bg-emerald-950/20 dark:text-emerald-400 px-2.5 py-1 rounded-full text-[10px] font-bold border border-emerald-250 dark:border-emerald-900/50">
                            <span class="w-1.5 h-1.5 rounded-full bg-emerald-550"></span>Active
                          </span>
                        <% } %>
                      </td>
                      <td class="py-4 px-6 text-right">
                        <div class="flex justify-end items-center gap-3">
                          <a href="/inventory/edit/<%= item._id %>" class="p-1.5 rounded-lg text-slate-400 hover:text-brand-orange hover:bg-orange-50 dark:hover:bg-orange-950/20 transition-all" title="Edit Stock">
                            <i data-lucide="edit-3" class="w-4 h-4"></i>
                          </a>
                          
                          <form action="/inventory/delete/<%= item._id %>" method="POST" class="inline">
                            <button type="submit" class="p-1.5 rounded-lg text-slate-400 hover:text-rose-500 hover:bg-rose-50 dark:hover:bg-rose-950/20 transition-all cursor-pointer" title="Delete Model">
                              <i data-lucide="trash-2" class="w-4 h-4"></i>
                            </button>
                          </form>
                        </div>
                      </td>
                    </tr>
                  <% }) %>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Right Column: Add Form (1/3 width) -->
      <div class="space-y-6">
        <div class="bg-white dark:bg-brand-darkCard border border-slate-200/60 dark:border-brand-darkBorder rounded-3xl p-6 shadow-sm">
          <div class="flex items-center gap-3 border-b border-slate-100 dark:border-brand-darkBorder pb-4 mb-6">
            <div class="w-10 h-10 rounded-2xl bg-orange-50 dark:bg-orange-950/20 text-brand-orange flex items-center justify-center">
              <i data-lucide="package-plus" class="w-5 h-5"></i>
            </div>
            <div>
              <h3 class="font-bold text-base text-slate-900 dark:text-white">Add Bike Model</h3>
              <p class="text-xs text-slate-400 dark:text-zinc-500">Record a new model to inventory ledger.</p>
            </div>
          </div>

          <form action="/inventory/add" method="POST" class="space-y-4">
            <!-- Bike Model Name -->
            <div>
              <label class="text-[10px] font-extrabold text-slate-400 dark:text-zinc-500 uppercase tracking-wider mb-2 block">Bike Model Name</label>
              <input 
                type="text" 
                name="bikeModel" 
                placeholder="e.g. Cruiser Model"
                required
                class="w-full bg-slate-50 dark:bg-brand-darkBg border border-slate-200 dark:border-brand-darkBorder rounded-xl px-4 py-2.5 text-sm text-slate-800 dark:text-zinc-200 focus:outline-none focus:border-brand-orange transition-all"
              />
            </div>

            <!-- Bike Colors -->
            <div>
              <label class="text-[10px] font-extrabold text-slate-400 dark:text-zinc-500 uppercase tracking-wider mb-2 block">Available Colors (comma-separated)</label>
              <input 
                type="text" 
                name="colors" 
                placeholder="e.g. Black, Red, Grey"
                required
                class="w-full bg-slate-50 dark:bg-brand-darkBg border border-slate-200 dark:border-brand-darkBorder rounded-xl px-4 py-2.5 text-sm text-slate-800 dark:text-zinc-200 focus:outline-none focus:border-brand-orange transition-all"
              />
            </div>

            <!-- Model Status -->
            <div>
              <label class="text-[10px] font-extrabold text-slate-400 dark:text-zinc-500 uppercase tracking-wider mb-2 block">Status</label>
              <select 
                name="status"
                class="w-full bg-slate-50 dark:bg-brand-darkBg border border-slate-200 dark:border-brand-darkBorder rounded-xl px-4 py-2.5 text-sm text-slate-800 dark:text-zinc-200 focus:outline-none focus:border-brand-orange transition-all cursor-pointer"
              >
                <option value="Active" selected>Active</option>
                <option value="Inactive">Inactive</option>
              </select>
            </div>

            <!-- Counts row -->
            <div class="grid grid-cols-2 gap-4">
              <div>
                <label class="text-[10px] font-extrabold text-slate-400 dark:text-zinc-500 uppercase tracking-wider mb-2 block">Stock Qty</label>
                <input 
                  type="number" 
                  name="stockQuantity" 
                  min="0"
                  value="0"
                  required
                  class="w-full bg-slate-50 dark:bg-brand-darkBg border border-slate-200 dark:border-brand-darkBorder rounded-xl px-4 py-2.5 text-sm text-slate-800 dark:text-zinc-200 focus:outline-none focus:border-brand-orange transition-all"
                />
              </div>
              
              <div>
                <label class="text-[10px] font-extrabold text-slate-400 dark:text-zinc-500 uppercase tracking-wider mb-2 block">Reserved Count</label>
                <input 
                  type="number" 
                  name="reservedBikes" 
                  min="0"
                  value="0"
                  required
                  class="w-full bg-slate-50 dark:bg-brand-darkBg border border-slate-200 dark:border-brand-darkBorder rounded-xl px-4 py-2.5 text-sm text-slate-800 dark:text-zinc-200 focus:outline-none focus:border-brand-orange transition-all"
                />
              </div>
            </div>

            <div class="grid grid-cols-2 gap-4">
              <div>
                <label class="text-[10px] font-extrabold text-slate-400 dark:text-zinc-500 uppercase tracking-wider mb-2 block">Sold Count</label>
                <input 
                  type="number" 
                  name="soldBikes" 
                  min="0"
                  value="0"
                  required
                  class="w-full bg-slate-50 dark:bg-brand-darkBg border border-slate-200 dark:border-brand-darkBorder rounded-xl px-4 py-2.5 text-sm text-slate-800 dark:text-zinc-200 focus:outline-none focus:border-brand-orange transition-all"
                />
              </div>

              <div>
                <label class="text-[10px] font-extrabold text-slate-400 dark:text-zinc-500 uppercase tracking-wider mb-2 block">Low Alert Level</label>
                <input 
                  type="number" 
                  name="lowStockThreshold" 
                  min="0"
                  value="2"
                  required
                  class="w-full bg-slate-50 dark:bg-brand-darkBg border border-slate-200 dark:border-brand-darkBorder rounded-xl px-4 py-2.5 text-sm text-slate-800 dark:text-zinc-200 focus:outline-none focus:border-brand-orange transition-all"
                />
              </div>
            </div>

            <!-- Submit Button -->
            <button 
              type="submit" 
              class="w-full mt-4 bg-brand-orange hover:bg-orange-600 text-white font-bold text-xs py-3.5 rounded-2xl transition-all shadow-md flex items-center justify-center gap-2 cursor-pointer"
            >
              <i data-lucide="plus" class="w-4 h-4"></i>
              <span>Add to Ledger</span>
            </button>
          </form>
        </div>
      </div>

    </div>

  </main>
</div>

<%- include('../partials/footer') %>
