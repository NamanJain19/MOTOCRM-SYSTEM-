<%- include('../partials/head') %>

<!-- Narrow Sidebar -->
<%- include('../partials/sidebar') %>

<!-- Main Wrapper -->
<div class="flex-1 flex flex-col min-w-0 transition-colors duration-200">
  <!-- Header -->
  <%- include('../partials/header') %>

  <!-- Content Container -->
  <main class="flex-1 overflow-y-auto p-8 space-y-6 bg-brand-lightBg dark:bg-brand-darkBg">
    
    <!-- Page Header -->
    <div class="flex items-center gap-3 border-b border-slate-200/60 dark:border-brand-darkBorder pb-5">
      <a href="/inventory" class="p-2 rounded-2xl bg-white dark:bg-brand-darkCard border border-slate-200/60 dark:border-brand-darkBorder hover:bg-slate-50 dark:hover:bg-zinc-800 text-slate-650 dark:text-zinc-300 transition-all">
        <i data-lucide="arrow-left" class="w-4 h-4"></i>
      </a>
      <div>
        <h1 class="text-3xl font-extrabold text-slate-900 dark:text-white tracking-tight">Edit Inventory Item</h1>
        <p class="text-sm text-slate-500 dark:text-zinc-400 mt-1">Modify stock ledger details for <%= item.bikeModel %>.</p>
      </div>
    </div>

    <!-- Error Alert if present -->
    <% if (error) { %>
      <div class="bg-rose-50 dark:bg-rose-950/20 border border-rose-200 dark:border-rose-900/50 rounded-2xl p-4 flex items-center gap-3 text-rose-700 dark:text-rose-400 text-sm max-w-2xl">
        <i data-lucide="alert-circle" class="w-5 h-5 shrink-0"></i>
        <span><%= error %></span>
      </div>
    <% } %>

    <!-- Form Container -->
    <div class="bg-white dark:bg-brand-darkCard border border-slate-200/60 dark:border-brand-darkBorder rounded-3xl p-8 shadow-sm max-w-2xl">
      <form action="/inventory/edit/<%= item._id %>" method="POST" class="space-y-6">
        <!-- Bike Model Name -->
        <div>
          <label class="text-[10px] font-extrabold text-slate-400 dark:text-zinc-500 uppercase tracking-wider mb-2 block">Bike Model Name</label>
          <input 
            type="text" 
            name="bikeModel" 
            value="<%= item.bikeModel %>"
            required
            class="w-full bg-slate-50 dark:bg-brand-darkBg border border-slate-200 dark:border-brand-darkBorder rounded-xl px-4 py-3 text-sm text-slate-800 dark:text-zinc-200 focus:outline-none focus:border-brand-orange transition-all"
          />
        </div>

        <!-- Counts row -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          <div>
            <label class="text-[10px] font-extrabold text-slate-400 dark:text-zinc-500 uppercase tracking-wider mb-2 block">Stock Quantity (Available)</label>
            <input 
              type="number" 
              name="stockQuantity" 
              min="0"
              value="<%= item.stockQuantity %>"
              required
              class="w-full bg-slate-50 dark:bg-brand-darkBg border border-slate-200 dark:border-brand-darkBorder rounded-xl px-4 py-3 text-sm text-slate-800 dark:text-zinc-200 focus:outline-none focus:border-brand-orange transition-all"
            />
          </div>
          
          <div>
            <label class="text-[10px] font-extrabold text-slate-400 dark:text-zinc-500 uppercase tracking-wider mb-2 block">Reserved Bikes (Held)</label>
            <input 
              type="number" 
              name="reservedBikes" 
              min="0"
              value="<%= item.reservedBikes %>"
              required
              class="w-full bg-slate-50 dark:bg-brand-darkBg border border-slate-200 dark:border-brand-darkBorder rounded-xl px-4 py-3 text-sm text-slate-800 dark:text-zinc-200 focus:outline-none focus:border-brand-orange transition-all"
            />
          </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          <div>
            <label class="text-[10px] font-extrabold text-slate-400 dark:text-zinc-500 uppercase tracking-wider mb-2 block">Sold Bikes (Delivered)</label>
            <input 
              type="number" 
              name="soldBikes" 
              min="0"
              value="<%= item.soldBikes %>"
              required
              class="w-full bg-slate-50 dark:bg-brand-darkBg border border-slate-200 dark:border-brand-darkBorder rounded-xl px-4 py-3 text-sm text-slate-800 dark:text-zinc-200 focus:outline-none focus:border-brand-orange transition-all"
            />
          </div>

          <div>
            <label class="text-[10px] font-extrabold text-slate-400 dark:text-zinc-500 uppercase tracking-wider mb-2 block">Low Stock Threshold Limit</label>
            <input 
              type="number" 
              name="lowStockThreshold" 
              min="0"
              value="<%= item.lowStockThreshold %>"
              required
              class="w-full bg-slate-50 dark:bg-brand-darkBg border border-slate-200 dark:border-brand-darkBorder rounded-xl px-4 py-3 text-sm text-slate-800 dark:text-zinc-200 focus:outline-none focus:border-brand-orange transition-all"
            />
          </div>
        </div>

        <!-- Buttons Row -->
        <div class="flex items-center gap-4 pt-4 border-t border-slate-100 dark:border-brand-darkBorder">
          <button 
            type="submit" 
            class="px-6 py-3 bg-brand-orange hover:bg-orange-600 text-white font-bold text-xs rounded-2xl transition-all shadow-md flex items-center gap-2 cursor-pointer"
          >
            <i data-lucide="check" class="w-4 h-4"></i>
            <span>Save Changes</span>
          </button>
          
          <a 
            href="/inventory" 
            class="px-6 py-3 bg-slate-100 hover:bg-slate-200 dark:bg-brand-darkBg dark:hover:bg-zinc-800 text-slate-600 dark:text-zinc-300 font-bold text-xs rounded-2xl border border-slate-200 dark:border-brand-darkBorder transition-all text-center"
          >
            Cancel
          </a>
        </div>
      </form>
    </div>

  </main>
</div>

<%- include('../partials/footer') %>
