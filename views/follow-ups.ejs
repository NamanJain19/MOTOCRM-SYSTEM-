    <script>
    (function() {
      function initFollowUps() {
      // Elements
      const toggleViewBtn = document.getElementById('toggleViewBtn');
      const toggleViewText = document.getElementById('toggleViewText');
      const toggleViewIcon = document.getElementById('toggleViewIcon');
      const listViewContainer = document.getElementById('listViewContainer');
      const calendarViewContainer = document.getElementById('calendarViewContainer');
      const calendarEl = document.getElementById('calendar');
      
      // Modal Elements
      const eventDetailsModal = document.getElementById('eventDetailsModal');
      const modalBackdrop = document.getElementById('modalBackdrop');
      const modalContent = document.getElementById('modalContent');
      const closeModalBtn = document.getElementById('closeModalBtn');
      
      const modalIconContainer = document.getElementById('modalIconContainer');
      const modalIcon = document.getElementById('modalIcon');
      const modalTypeBadge = document.getElementById('modalTypeBadge');
      const modalTitle = document.getElementById('modalTitle');
      const modalDateStr = document.getElementById('modalDateStr');
      const modalCustName = document.getElementById('modalCustName');
      const modalCustPhone = document.getElementById('modalCustPhone');
      const modalCustEmail = document.getElementById('modalCustEmail');
      const modalDesc = document.getElementById('modalDesc');
      const modalDescContainer = document.getElementById('modalDescContainer');
      const modalSalesperson = document.getElementById('modalSalesperson');
      const modalSalespersonContainer = document.getElementById('modalSalespersonContainer');
      const modalRescheduleDate = document.getElementById('modalRescheduleDate');
      const modalRescheduleBtn = document.getElementById('modalRescheduleBtn');
      const modalCallBtn = document.getElementById('modalCallBtn');
      const modalStatusActions = document.getElementById('modalStatusActions');
      const modalMissedBtn = document.getElementById('modalMissedBtn');
      const modalCompleteBtn = document.getElementById('modalCompleteBtn');

      const modalReassignBtn = document.getElementById('modalReassignBtn');
      const modalReassignSelect = document.getElementById('modalReassignSelect');

      let calendar = null;
      let activeEvent = null; // Store currently selected event info
      let currentView = localStorage.getItem('motocrm-followups-view') || 'list';

      // Initialize initial view state on load
      if (currentView === 'calendar') {
        listViewContainer.classList.add('hidden');
        listViewContainer.classList.remove('block');
        calendarViewContainer.classList.remove('hidden');
        toggleViewText.textContent = 'List View';
        toggleViewIcon.setAttribute('data-lucide', 'list');
        setTimeout(() => {
          initializeCalendar();
        }, 100);
      }

      // Toggle View Handler
      toggleViewBtn.addEventListener('click', () => {
        if (currentView === 'list') {
          // Switch to Calendar
          listViewContainer.classList.add('hidden');
          listViewContainer.classList.remove('block');
          calendarViewContainer.classList.remove('hidden');
          
          toggleViewText.textContent = 'List View';
          toggleViewIcon.setAttribute('data-lucide', 'list');
          if (window.lucide) window.lucide.createIcons();
          
          currentView = 'calendar';
          localStorage.setItem('motocrm-followups-view', 'calendar');
          
          // Initialize FullCalendar if not already
          if (!calendar) {
            initializeCalendar();
          } else {
            calendar.render();
          }
        } else {
          // Switch to List
          calendarViewContainer.classList.add('hidden');
          listViewContainer.classList.remove('hidden');
          listViewContainer.classList.add('block');
          
          toggleViewText.textContent = 'Calendar View';
          toggleViewIcon.setAttribute('data-lucide', 'calendar');
          if (window.lucide) window.lucide.createIcons();
          
          currentView = 'list';
          localStorage.setItem('motocrm-followups-view', 'list');
        }
      });

      // Initialize FullCalendar
      function initializeCalendar() {
        calendar = new FullCalendar.Calendar(calendarEl, {
          initialView: 'dayGridMonth',
          headerToolbar: {
            left: 'prev,next today',
            center: 'title',
            right: 'dayGridMonth,timeGridWeek,timeGridDay'
          },
          events: '/follow-ups/events',
          eventClick: function(info) {
            openModal(info.event);
          },
          loading: function(isLoading) {
            if (isLoading) {
              calendarViewContainer.classList.add('opacity-70');
            } else {
              calendarViewContainer.classList.remove('opacity-70');
            }
          },
          eventTimeFormat: {
            hour: '2-digit',
            minute: '2-digit',
            meridiem: 'short'
          }
        });
        calendar.render();
      }

      // Open Modal with Event data
      function openModal(fcEvent) {
        activeEvent = fcEvent;
        const props = fcEvent.extendedProps;
        
        // Header styling & icon based on event type
        if (props.type === 'test_ride') {
          modalTypeBadge.textContent = 'Test Ride';
          modalTypeBadge.className = 'text-[9px] font-extrabold px-2 py-0.5 rounded-full uppercase tracking-wider bg-purple-50 text-purple-600 dark:bg-purple-950/40 dark:text-purple-300 border border-purple-100 dark:border-purple-950/30';
          modalIconContainer.className = 'w-10 h-10 rounded-2xl flex items-center justify-center shrink-0 text-purple-600 bg-purple-50 dark:bg-purple-950/20';
          modalIcon.setAttribute('data-lucide', 'bike');
          
          // Salesperson visible, reschedule date hidden
          modalSalespersonContainer.classList.remove('hidden');
          modalSalesperson.textContent = props.salesperson;
          document.getElementById('modalRescheduleSection').classList.add('hidden');
          document.getElementById('modalReassignSection').classList.add('hidden');
          
          // Status actions: For test ride, hide follow up controls
          modalStatusActions.classList.add('hidden');
        } else {
          modalTypeBadge.textContent = 'Follow-Up';
          modalTypeBadge.className = 'text-[9px] font-extrabold px-2 py-0.5 rounded-full uppercase tracking-wider bg-orange-50 text-brand-orange dark:bg-orange-950/40 dark:text-orange-300 border border-orange-100 dark:border-orange-950/30';
          modalIconContainer.className = 'w-10 h-10 rounded-2xl flex items-center justify-center shrink-0 text-brand-orange bg-orange-50 dark:bg-orange-950/30';
          modalIcon.setAttribute('data-lucide', 'phone');
          
          // Salesperson hidden, reschedule visible
          modalSalespersonContainer.classList.add('hidden');
          document.getElementById('modalRescheduleSection').classList.remove('hidden');
          document.getElementById('modalReassignSection').classList.remove('hidden');

          if (props.assignedTo) {
            modalReassignSelect.value = props.assignedTo._id || props.assignedTo;
          } else {
            modalReassignSelect.value = '';
          }
          
          // Status actions: show follow up controls
          modalStatusActions.classList.remove('hidden');
          
          // Handle button states based on task status
          if (props.status === 'Completed') {
            modalCompleteBtn.disabled = true;
            modalCompleteBtn.classList.add('opacity-50', 'cursor-not-allowed');
            modalMissedBtn.disabled = true;
            modalMissedBtn.classList.add('opacity-50', 'cursor-not-allowed');
          } else {
            modalCompleteBtn.disabled = false;
            modalCompleteBtn.classList.remove('opacity-50', 'cursor-not-allowed');
            modalMissedBtn.disabled = false;
            modalMissedBtn.classList.remove('opacity-50', 'cursor-not-allowed');
          }
        }
        
        // Set title and details
        modalTitle.textContent = fcEvent.title;
        
        const formattedDate = new Date(fcEvent.start).toLocaleString([], {
          weekday: 'long',
          month: 'short',
          day: 'numeric',
          hour: '2-digit',
          minute: '2-digit'
        });
        modalDateStr.textContent = formattedDate;
        
        const modalSMSBtn = document.getElementById('modalSMSBtn');
        if (props.lead) {
          modalCustName.textContent = props.lead.name;
          modalCustPhone.textContent = props.lead.phone;
          modalCustEmail.textContent = props.lead.email || 'No email provided';
          modalCallBtn.setAttribute('href', `tel:${props.lead.phone}`);
          modalCallBtn.classList.remove('hidden');
          if (modalSMSBtn) {
            modalSMSBtn.classList.remove('hidden');
            modalSMSBtn.onclick = (e) => {
              closeModal();
              openSMSModal(props.lead.phone, props.lead._id, 'Lead');
            };
          }
          
          modalCallBtn.onclick = (e) => {
            logCall(props.type === 'task' ? fcEvent.id : null, props.type === 'test_ride' ? fcEvent.id : null, props.lead._id);
          };
        } else {
          modalCustName.textContent = 'N/A';
          modalCustPhone.textContent = 'N/A';
          modalCustEmail.textContent = 'N/A';
          modalCallBtn.classList.add('hidden');
          if (modalSMSBtn) modalSMSBtn.classList.add('hidden');
        }
        
        if (fcEvent.description) {
          modalDescContainer.classList.remove('hidden');
          modalDesc.textContent = `"${fcEvent.description}"`;
        } else {
          modalDescContainer.classList.add('hidden');
        }
        
        // Set reschedule default date-time input
        const d = new Date(fcEvent.start);
        const year = d.getFullYear();
        const month = String(d.getMonth() + 1).padStart(2, '0');
        const day = String(d.getDate()).padStart(2, '0');
        const hours = String(d.getHours()).padStart(2, '0');
        const minutes = String(d.getMinutes()).padStart(2, '0');
        modalRescheduleDate.value = `${year}-${month}-${day}T${hours}:${minutes}`;

        if (window.lucide) window.lucide.createIcons();

        // Show modal container
        eventDetailsModal.classList.remove('hidden');
        setTimeout(() => {
          modalBackdrop.classList.remove('opacity-0');
          modalContent.classList.remove('scale-95', 'opacity-0');
        }, 10);
      }

      // Close Modal Handler
      function closeModal() {
        modalBackdrop.classList.add('opacity-0');
        modalContent.classList.add('scale-95', 'opacity-0');
        setTimeout(() => {
          eventDetailsModal.classList.add('hidden');
          activeEvent = null;
        }, 300);
      }

      closeModalBtn.addEventListener('click', closeModal);
      modalBackdrop.addEventListener('click', closeModal);

      // Reassign Single Task inside Event Modal
      modalReassignBtn.addEventListener('click', async () => {
        if (!activeEvent || activeEvent.extendedProps.type !== 'task') return;
        const userId = modalReassignSelect.value;
        if (!userId) {
          showToast('Please select a salesperson.', 'error');
          return;
        }
        modalReassignBtn.disabled = true;
        modalReassignBtn.innerHTML = 'Saving...';
        try {
          const res = await fetch(`/follow-ups/reassign/${activeEvent.id}`, {
            method: 'POST',
            headers: {
              'Accept': 'application/json',
              'Content-Type': 'application/json'
            },
            body: JSON.stringify({ userId })
          });
          const data = await res.json();
          if (data.success) {
            showToast(data.message, 'success');
            if (calendar) calendar.refetchEvents();
            closeModal();
            setTimeout(() => {
              window.location.reload();
            }, 1000);
          } else {
            showToast(data.message || 'Error reassigning task.', 'error');
            modalReassignBtn.disabled = false;
            modalReassignBtn.textContent = 'Reassign';
          }
        } catch (err) {
          console.error(err);
          showToast('Connection error. Please try again.', 'error');
          modalReassignBtn.disabled = false;
          modalReassignBtn.textContent = 'Reassign';
        }
      });

      // Mark Completed AJAX Handler from Modal
      modalCompleteBtn.addEventListener('click', async () => {
        if (!activeEvent || activeEvent.extendedProps.type !== 'task') return;
        
        modalCompleteBtn.disabled = true;
        modalCompleteBtn.innerHTML = `<span class="inline-block w-4 h-4 border-2 border-white border-t-transparent rounded-full animate-spin"></span> Processing...`;
        
        try {
          const res = await fetch(`/follow-ups/done/${activeEvent.id}`, {
            method: 'POST',
            headers: {
              'Accept': 'application/json',
              'Content-Type': 'application/json'
            }
          });
          const data = await res.json();
          
          if (data.success) {
            showToast(data.message, 'success');
            if (calendar) calendar.refetchEvents();
            closeModal();
            setTimeout(() => {
              window.location.reload();
            }, 1000);
          } else {
            showToast(data.message || 'Error completing follow-up.', 'error');
            resetCompleteBtn();
          }
        } catch (err) {
          console.error(err);
          showToast('Connection error. Please try again.', 'error');
          resetCompleteBtn();
        }
      });

      function resetCompleteBtn() {
        modalCompleteBtn.disabled = false;
        modalCompleteBtn.innerHTML = `<i data-lucide="check" class="w-3.5 h-3.5"></i> <span>Complete Follow-Up</span>`;
        if (window.lucide) window.lucide.createIcons();
      }

      // Mark Missed AJAX Handler from Modal
      modalMissedBtn.addEventListener('click', async () => {
        if (!activeEvent || activeEvent.extendedProps.type !== 'task') return;
        
        modalMissedBtn.disabled = true;
        modalMissedBtn.innerHTML = `<span class="inline-block w-4 h-4 border-2 border-rose-500 border-t-transparent rounded-full animate-spin"></span> Processing...`;
        
        try {
          const res = await fetch(`/follow-ups/missed/${activeEvent.id}`, {
            method: 'POST',
            headers: {
              'Accept': 'application/json',
              'Content-Type': 'application/json'
            }
          });
          const data = await res.json();
          
          if (data.success) {
            showToast(data.message, 'success');
            if (calendar) calendar.refetchEvents();
            closeModal();
            setTimeout(() => {
              window.location.reload();
            }, 1000);
          } else {
            showToast(data.message || 'Error marking missed.', 'error');
            resetMissedBtn();
          }
        } catch (err) {
          console.error(err);
          showToast('Connection error. Please try again.', 'error');
          resetMissedBtn();
        }
      });

      function resetMissedBtn() {
        modalMissedBtn.disabled = false;
        modalMissedBtn.innerHTML = `<i data-lucide="alert-circle" class="w-3.5 h-3.5"></i> <span>Mark Missed</span>`;
        if (window.lucide) window.lucide.createIcons();
      }

      modalRescheduleBtn.addEventListener('click', async () => {
        if (!activeEvent || activeEvent.extendedProps.type !== 'task') return;
        
        const newDateVal = modalRescheduleDate.value;
        if (!newDateVal) {
          showToast('Please pick a date and time.', 'error');
          return;
        }
        
        modalRescheduleBtn.disabled = true;
        modalRescheduleBtn.innerHTML = `<span class="inline-block w-4 h-4 border-2 border-white border-t-transparent rounded-full animate-spin"></span> Saving...`;
        
        try {
          const res = await fetch(`/follow-ups/reschedule/${activeEvent.id}`, {
            method: 'POST',
            headers: {
              'Accept': 'application/json',
              'Content-Type': 'application/json'
            },
            body: JSON.stringify({
              newDate: newDateVal,
              priority: activeEvent.extendedProps.priority
            })
          });
          const data = await res.json();
          
          if (data.success) {
            showToast(data.message, 'success');
            if (calendar) calendar.refetchEvents();
            closeModal();
            setTimeout(() => {
              window.location.reload();
            }, 1000);
          } else {
            showToast(data.message || 'Error rescheduling.', 'error');
            resetRescheduleBtn();
          }
        } catch (err) {
          console.error(err);
          showToast('Connection error. Please try again.', 'error');
          resetRescheduleBtn();
        }
      });

      function resetRescheduleBtn() {
        modalRescheduleBtn.disabled = false;
        modalRescheduleBtn.textContent = 'Reschedule';
      }

      // General logCall function
      async function logCall(taskId, testRideId, leadId) {
        try {
          const res = await fetch('/follow-ups/call', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json'
            },
            body: JSON.stringify({ taskId, testRideId, leadId })
          });
          const data = await res.json();
          if (data.success) {
            showToast(data.message, 'success');
          } else {
            showToast(data.message || 'Error logging call.', 'error');
          }
        } catch (err) {
          console.error('Call logging error:', err);
        }
      }

      // INTERCEPT LIST-VIEW FORMS FOR AJAX TRANSITIONS
      document.addEventListener('submit', async (e) => {
        const form = e.target;
        const action = form.getAttribute('action') || '';
        
        if (action.includes('/follow-ups/done/') || action.includes('/follow-ups/reschedule/')) {
          e.preventDefault();
          
          const card = form.closest('.task-card, .overdue-item');
          if (card) {
            card.style.opacity = '0.5';
          }
          
          try {
            const formData = new FormData(form);
            const dataObj = {};
            formData.forEach((value, key) => {
              dataObj[key] = value;
            });
            
            const res = await fetch(action, {
              method: 'POST',
              headers: {
                'Accept': 'application/json',
                'Content-Type': 'application/json'
              },
              body: JSON.stringify(dataObj)
            });
            const data = await res.json();
            
            if (data.success) {
              showToast(data.message, 'success');
              
              if (card) {
                card.style.transition = 'all 0.3s ease';
                card.style.transform = 'scale(0.95)';
                card.style.opacity = '0';
                setTimeout(() => {
                  card.remove();
                  const remainingTasks = document.querySelectorAll('#listViewContainer .task-card, #listViewContainer .overdue-item');
                  if (remainingTasks.length === 0) {
                    window.location.reload();
                  }
                }, 300);
              } else {
                window.location.reload();
              }
              
              if (calendar) calendar.refetchEvents();
            } else {
              showToast(data.message || 'Action failed.', 'error');
              if (card) card.style.opacity = '1';
            }
          } catch (err) {
            console.error(err);
            showToast('Connection error. Please try again.', 'error');
            if (card) card.style.opacity = '1';
          }
        }
      });

      // Intercept all tel: links in the document for call activity logging (only for non-modal links)
      document.addEventListener('click', (e) => {
        const callLink = e.target.closest('a[href^="tel:"]');
        if (callLink && !callLink.closest('#eventDetailsModal')) {
          const taskId = callLink.getAttribute('data-task-id') || null;
          const leadId = callLink.getAttribute('data-lead-id') || null;
          logCall(taskId, null, leadId);
        }
      });

      // Reassign All Modal Event Listeners
      const reassignAllModal = document.getElementById('reassignAllModal');
      const reassignAllBackdrop = document.getElementById('reassignAllBackdrop');
      const reassignAllContent = document.getElementById('reassignAllContent');
      const reassignAllBtn = document.getElementById('reassignAllBtn');
      const closeReassignAllBtn = document.getElementById('closeReassignAllBtn');
      const cancelReassignAllBtn = document.getElementById('cancelReassignAllBtn');
      const confirmReassignAllBtn = document.getElementById('confirmReassignAllBtn');
      const reassignAllSelect = document.getElementById('reassignAllSelect');

      function openReassignAll(e) {
        if (e) e.preventDefault();
        reassignAllModal.classList.remove('hidden');
        setTimeout(() => {
          reassignAllBackdrop.classList.remove('opacity-0');
          reassignAllContent.classList.remove('scale-95', 'opacity-0');
        }, 10);
      }

      function closeReassignAll() {
        reassignAllBackdrop.classList.add('opacity-0');
        reassignAllContent.classList.add('scale-95', 'opacity-0');
        setTimeout(() => {
          reassignAllModal.classList.add('hidden');
        }, 300);
      }

      if (reassignAllBtn) reassignAllBtn.addEventListener('click', openReassignAll);
      if (closeReassignAllBtn) closeReassignAllBtn.addEventListener('click', closeReassignAll);
      if (cancelReassignAllBtn) cancelReassignAllBtn.addEventListener('click', closeReassignAll);
      if (reassignAllBackdrop) reassignAllBackdrop.addEventListener('click', closeReassignAll);

      if (confirmReassignAllBtn) {
        confirmReassignAllBtn.addEventListener('click', async () => {
          const userId = reassignAllSelect.value;
          if (!userId) {
            showToast('Please select a salesperson.', 'error');
            return;
          }
          confirmReassignAllBtn.disabled = true;
          confirmReassignAllBtn.innerHTML = 'Processing...';
          try {
            const res = await fetch('/follow-ups/reassign-all', {
              method: 'POST',
              headers: {
                'Accept': 'application/json',
                'Content-Type': 'application/json'
              },
              body: JSON.stringify({ userId })
            });
            const data = await res.json();
            if (data.success) {
              showToast(data.message, 'success');
              closeReassignAll();
              setTimeout(() => {
                window.location.reload();
              }, 1000);
            } else {
              showToast(data.message || 'Error reassigning tasks.', 'error');
              confirmReassignAllBtn.disabled = false;
              confirmReassignAllBtn.textContent = 'Confirm Reassign';
            }
          } catch (err) {
            console.error(err);
            showToast('Connection error. Please try again.', 'error');
            confirmReassignAllBtn.disabled = false;
            confirmReassignAllBtn.textContent = 'Confirm Reassign';
          }
        });
      }

      // View All Missed Tasks Modal Event Listeners
      const viewAllMissedModal = document.getElementById('viewAllMissedModal');
      const viewAllMissedBackdrop = document.getElementById('viewAllMissedBackdrop');
      const viewAllMissedContent = document.getElementById('viewAllMissedContent');
      const viewAllMissedBtn = document.getElementById('viewAllMissedBtn');
      const closeViewAllMissedBtn = document.getElementById('closeViewAllMissedBtn');
      const cancelViewAllMissedBtn = document.getElementById('cancelViewAllMissedBtn');

      function openViewAllMissed(e) {
        if (e) e.preventDefault();
        viewAllMissedModal.classList.remove('hidden');
        setTimeout(() => {
          viewAllMissedBackdrop.classList.remove('opacity-0');
          viewAllMissedContent.classList.remove('scale-95', 'opacity-0');
        }, 10);
      }

      function closeViewAllMissed() {
        viewAllMissedBackdrop.classList.add('opacity-0');
        viewAllMissedContent.classList.add('scale-95', 'opacity-0');
        setTimeout(() => {
          viewAllMissedModal.classList.add('hidden');
        }, 300);
      }

      if (viewAllMissedBtn) viewAllMissedBtn.addEventListener('click', openViewAllMissed);
      if (closeViewAllMissedBtn) closeViewAllMissedBtn.addEventListener('click', closeViewAllMissed);
      if (cancelViewAllMissedBtn) cancelViewAllMissedBtn.addEventListener('click', closeViewAllMissed);
      if (viewAllMissedBackdrop) viewAllMissedBackdrop.addEventListener('click', closeViewAllMissed);

      }
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initFollowUps);
      } else {
        initFollowUps();
      }
    })();
    </script>
  </main>
</div>

<%- include('partials/footer') %>
