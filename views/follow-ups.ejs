<%- include('partials/head') %>

<!-- Narrow Sidebar -->
<%- include('partials/sidebar') %>

<!-- Main Wrapper -->
<div class="flex-1 flex flex-col min-w-0 transition-colors duration-200 bg-brand-lightBg dark:bg-brand-darkBg">
  <!-- Header -->
  <%- include('partials/header') %>

  <!-- Content Container -->
  <% var nextDay = new Date(Date.now() + 24*3600000).toISOString().split('T')[0]; %>
  <main class="flex-1 overflow-y-auto p-8 space-y-8">
    
    <!-- Page Header -->
    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 border-b border-slate-200/60 dark:border-brand-darkBorder pb-5">
      <div>
        <h1 class="text-3xl font-extrabold text-slate-900 dark:text-white tracking-tight">Follow Ups</h1>
        <p class="text-sm text-slate-500 dark:text-zinc-400 mt-1">Stay on top of your sales pipeline. Manage today's tasks and recover missed opportunities.</p>
      </div>
      
      <!-- Actions -->
      <div class="flex items-center gap-3">
        <button id="toggleViewBtn" class="flex items-center gap-2 px-4 py-2.5 rounded-2xl text-sm font-semibold text-slate-700 hover:text-slate-900 bg-white dark:bg-brand-darkCard dark:text-zinc-300 dark:hover:bg-zinc-800 border border-slate-200 dark:border-brand-darkBorder transition-all cursor-pointer">
          <i id="toggleViewIcon" data-lucide="calendar" class="w-4 h-4 text-slate-400"></i>
          <span id="toggleViewText">Calendar View</span>
        </button>
        <a href="/leads/add" class="flex items-center gap-2 bg-brand-orange hover:bg-orange-600 text-white font-bold text-sm px-4 py-2.5 rounded-2xl transition-all shadow-sm">
          <i data-lucide="plus" class="w-4 h-4"></i>
          <span>Add New Lead</span>
        </a>
      </div>
    </div>

    <!-- List View Container -->
    <div id="listViewContainer" class="block">
      <!-- Main Two-Column Layout Grid -->
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      
      <!-- Left Column (Today's Queue & Recently Completed) - Spans 2/3 -->
      <div class="lg:col-span-2 space-y-8">
        
        <!-- Today's Queue Section -->
        <div class="space-y-4">
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-3">
              <h3 class="font-bold text-lg text-slate-900 dark:text-white">Today's Queue</h3>
              <span class="px-2.5 py-0.5 text-xs font-bold bg-orange-50 text-brand-orange dark:bg-orange-950/40 dark:text-orange-300 rounded-full border border-orange-100 dark:border-orange-950/30">
                <%= todayQueue.length %> Pending
              </span>
            </div>
          </div>

          <!-- Queue List -->
          <div class="space-y-4">
            <% if (todayQueue.length === 0) { %>
              <div class="bg-white dark:bg-brand-darkCard border border-slate-200/60 dark:border-brand-darkBorder rounded-3xl p-8 text-center text-slate-400 dark:text-zinc-500">
                <i data-lucide="check-circle" class="w-10 h-10 mx-auto mb-3 text-emerald-500"></i>
                All caught up for today! No pending follow-up tasks remaining.
              </div>
            <% } else { %>
              <% todayQueue.forEach(task => { 
                // Set icons based on priority or title
                let iconName = 'phone';
                let iconColor = 'text-brand-orange bg-orange-50 dark:bg-orange-950/30';
                let leftBorder = 'border-slate-200 dark:border-brand-darkBorder';

                if (task.title.toLowerCase().includes('test ride') || task.title.toLowerCase().includes(' ducati') || task.title.toLowerCase().includes('street glide')) {
                  iconName = 'bike';
                  iconColor = 'text-emerald-500 bg-emerald-50 dark:bg-emerald-950/20';
                } else if (task.title.toLowerCase().includes('finance') || task.title.toLowerCase().includes('document')) {
                  iconName = 'file-text';
                  iconColor = 'text-purple-600 bg-purple-50 dark:bg-purple-950/20';
                }

                if (task.priority === 'URGENT') {
                  leftBorder = 'border-l-4 border-l-rose-500';
                } else if (task.priority === 'HIGH') {
                  leftBorder = 'border-l-4 border-l-orange-500';
                }
              %>
                <!-- Task Card -->
                <div class="task-card bg-white dark:bg-brand-darkCard border border-slate-200/60 dark:border-brand-darkBorder <%= leftBorder %> rounded-3xl p-5 shadow-sm flex flex-col sm:flex-row sm:items-center justify-between gap-4 hover:shadow-md transition-all">
                  <div class="flex items-center gap-4">
                    <div class="w-10 h-10 rounded-2xl flex items-center justify-center shrink-0 <%= iconColor %>">
                      <i data-lucide="<%= iconName %>" class="w-5 h-5"></i>
                    </div>
                    <div>
                      <h4 class="font-bold text-slate-800 dark:text-zinc-200"><%= task.title %></h4>
                      <p class="text-xs text-slate-500 dark:text-zinc-400 mt-1">
                        <%= task.description || `Customer: ${task.lead ? task.lead.name : 'Unknown'} • Due Today` %>
                      </p>
                    </div>
                  </div>

                  <div class="flex items-center gap-2">
                    <!-- Priority Badge -->
                    <span class="px-2.5 py-0.5 text-[9px] font-extrabold rounded-full border mr-2 inline-block
                      <%= task.priority === 'URGENT' ? 'bg-rose-50 text-rose-600 dark:bg-rose-950/30 dark:text-rose-400 border-rose-100' : '' %>
                      <%= task.priority === 'HIGH' ? 'bg-orange-50 text-brand-orange dark:bg-orange-950/30 dark:text-orange-400 border-orange-100' : '' %>
                      <%= task.priority === 'NORMAL' ? 'bg-blue-50 text-sky-600 dark:bg-sky-950/30 dark:text-sky-400 border-blue-100' : '' %>
                    ">
                      <%= task.priority %>
                    </span>

                    <!-- Mark Done form -->
                    <form action="/follow-ups/done/<%= task._id %>" method="POST" class="inline">
                      <button type="submit" class="flex items-center gap-1.5 px-3 py-1.5 rounded-xl bg-brand-orange hover:bg-orange-600 text-white text-xs font-bold cursor-pointer transition-all shadow-sm">
                        <i data-lucide="check" class="w-3.5 h-3.5"></i>
                        <span>Mark Done</span>
                      </button>
                    </form>

                    <!-- Quick reschedule to tomorrow -->
                    <form action="/follow-ups/reschedule/<%= task._id %>" method="POST" class="inline">
                      <input type="hidden" name="newDate" value="<%= nextDay %>" />
                      <button type="submit" title="Reschedule to Tomorrow" class="p-1.5 rounded-xl border border-slate-200 dark:border-brand-darkBorder bg-white dark:bg-brand-darkCard text-slate-500 hover:text-slate-800 dark:text-zinc-400 dark:hover:text-white flex items-center justify-center cursor-pointer transition-all">
                        <i data-lucide="calendar-range" class="w-4 h-4"></i>
                      </button>
                    </form>

                    <!-- Contact/Call action -->
                    <% if (task.lead && task.lead.phone) { %>
                      <a href="tel:<%= task.lead.phone %>" data-task-id="<%= task._id %>" data-lead-id="<%= task.lead._id %>" title="Call Customer" class="p-1.5 rounded-xl border border-slate-200/60 dark:border-brand-darkBorder bg-white dark:bg-brand-darkCard text-slate-500 hover:text-slate-800 dark:text-zinc-400 dark:hover:text-white flex items-center justify-center transition-all">
                        <i data-lucide="phone" class="w-4 h-4"></i>
                      </a>

                      <!-- Send SMS Action -->
                      <button type="button" onclick="openSMSModal('<%= task.lead.phone %>', '<%= task.lead._id %>', 'Lead')" title="Send SMS" class="p-1.5 rounded-xl border border-slate-200/60 dark:border-brand-darkBorder bg-white dark:bg-brand-darkCard text-slate-500 hover:text-slate-800 dark:text-zinc-400 dark:hover:text-white flex items-center justify-center cursor-pointer transition-all">
                        <i data-lucide="message-square" class="w-4 h-4"></i>
                      </button>
                    <% } %>
                  </div>
                </div>
              <% }) %>
            <% } %>
          </div>
        </div>

        <!-- Recently Completed Section -->
        <div class="space-y-4">
          <div class="flex items-center gap-2 text-slate-500 dark:text-zinc-400">
            <i data-lucide="check-check" class="w-5 h-5 text-emerald-500"></i>
            <h3 class="font-bold text-sm uppercase tracking-wider">Recently Completed</h3>
          </div>

          <div class="bg-white dark:bg-brand-darkCard border border-slate-200/60 dark:border-brand-darkBorder rounded-3xl divide-y divide-slate-100 dark:divide-brand-darkBorder shadow-sm overflow-hidden">
            <% if (recentlyCompleted.length === 0) { %>
              <div class="p-6 text-center text-slate-400 dark:text-zinc-500 text-sm">
                No tasks completed yet today.
              </div>
            <% } else { %>
              <% recentlyCompleted.forEach(task => { %>
                <div class="p-5 flex items-center justify-between gap-4 hover:bg-slate-50/40 dark:hover:bg-brand-darkCard/40 transition-colors">
                  <div class="flex items-center gap-3">
                    <span class="w-8 h-8 rounded-full bg-slate-100 dark:bg-brand-darkBg flex items-center justify-center text-slate-400 dark:text-zinc-600">
                      <i data-lucide="check" class="w-4 h-4"></i>
                    </span>
                    <span class="text-sm font-semibold text-slate-600 dark:text-zinc-400 line-through font-medium">
                      <%= task.title %> <%= task.lead ? `(Customer: ${task.lead.name})` : '' %>
                    </span>
                  </div>
                  <span class="text-[10px] font-bold text-slate-400 dark:text-zinc-500 uppercase">
                    Done <%= new Date(task.completedAt).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }) %>
                  </span>
                </div>
              <% }) %>
            <% } %>
          </div>
        </div>

      </div>

      <!-- Right Column (Overdue Alerts, KPIs, Suggestions) - Spans 1/3 -->
      <div class="space-y-8">
        
        <!-- Overdue Tasks Card -->
        <div class="bg-white dark:bg-brand-darkCard border border-slate-200/60 dark:border-brand-darkBorder border-t-4 border-t-rose-500 rounded-3xl p-6 shadow-sm">
          <div class="flex justify-between items-center border-b border-slate-100 dark:border-brand-darkBorder pb-4 mb-4">
            <div class="flex items-center gap-2 text-rose-500">
              <i data-lucide="alert-triangle" class="w-5 h-5"></i>
              <h3 class="font-bold text-base">Overdue (<%= overdue.length %>)</h3>
            </div>
            <a href="#" id="reassignAllBtn" class="text-xs font-bold text-brand-orange hover:underline">Reassign All</a>
          </div>

          <div class="space-y-5 divide-y divide-slate-100 dark:divide-brand-darkBorder">
            <% if (overdue.length === 0) { %>
              <p class="text-sm text-slate-400 dark:text-zinc-500 py-4 text-center">No overdue tasks. Outstanding job!</p>
            <% } else { %>
              <% overdue.forEach((task, idx) => { 
                // Calculate days overdue
                const diffTime = Math.abs(new Date() - new Date(task.dueDate));
                const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));
                const overdueStr = diffDays === 1 ? 'Yesterday' : `${diffDays} days ago`;
              %>
                <div class="overdue-item space-y-2 <%= idx > 0 ? 'pt-4 border-t border-slate-100 dark:border-brand-darkBorder' : '' %>" data-task-id="<%= task._id %>">
                  <div class="flex justify-between items-start">
                    <h4 class="font-bold text-sm text-slate-800 dark:text-zinc-200"><%= task.lead ? task.lead.name : 'Unknown' %> - Call Back</h4>
                    <span class="text-[10px] font-extrabold text-rose-500 uppercase whitespace-nowrap"><%= overdueStr %></span>
                  </div>
                  <p class="text-xs text-slate-500 dark:text-zinc-400 italic font-medium leading-relaxed">
                    "<%= task.description || (task.lead && task.lead.notes) || 'Waiting for follow up' %>"
                  </p>
                  
                  <div class="flex items-center justify-end gap-2 pt-2">
                    <!-- Complete action -->
                    <form action="/follow-ups/done/<%= task._id %>" method="POST" class="inline">
                      <button type="submit" class="p-1 rounded-lg bg-emerald-50 text-emerald-600 hover:bg-emerald-600 hover:text-white dark:bg-brand-darkBg dark:text-emerald-400 dark:hover:bg-emerald-950/20 flex items-center justify-center cursor-pointer transition-all">
                        <i data-lucide="check" class="w-3.5 h-3.5"></i>
                      </button>
                    </form>
                    <!-- Reschedule to tomorrow -->
                    <form action="/follow-ups/reschedule/<%= task._id %>" method="POST" class="inline">
                      <input type="hidden" name="newDate" value="<%= nextDay %>" />
                      <button type="submit" class="p-1 rounded-lg bg-blue-50 text-brand-orange hover:bg-brand-orange hover:text-white dark:bg-brand-darkBg dark:text-orange-400 dark:hover:bg-orange-950/20 flex items-center justify-center cursor-pointer transition-all">
                        <i data-lucide="calendar" class="w-3.5 h-3.5"></i>
                      </button>
                    </form>
                  </div>
                </div>
              <% }) %>
            <% } %>
          </div>

          <div class="border-t border-slate-100 dark:border-brand-darkBorder mt-6 pt-4 text-center">
            <a href="#" id="viewAllMissedBtn" class="text-xs font-bold text-brand-orange hover:underline flex items-center justify-center gap-1">
              <span>View all missed tasks</span>
              <i data-lucide="chevron-right" class="w-3.5 h-3.5"></i>
            </a>
          </div>
        </div>

        <!-- Metrics Grid -->
        <div class="grid grid-cols-2 gap-4">
          <!-- Daily Target -->
          <div class="bg-gradient-to-br from-[#ff5c35] to-[#d43d18] text-white rounded-3xl p-5 shadow-sm flex flex-col justify-between min-h-[120px]">
            <div class="flex justify-between items-start">
              <span class="text-[9px] font-extrabold uppercase tracking-widest text-orange-100">Daily Target</span>
              <i data-lucide="trending-up" class="w-4 h-4 text-orange-100"></i>
            </div>
            <div class="mt-4">
              <span class="text-3xl font-extrabold block"><%= metrics.dailyTarget %>%</span>
              <span class="text-[9px] font-semibold text-orange-100 uppercase tracking-wider block mt-1">Completion rate</span>
            </div>
          </div>

          <!-- Follow-ups Logged -->
          <div class="bg-white dark:bg-brand-darkCard border border-slate-200/60 dark:border-brand-darkBorder rounded-3xl p-5 shadow-sm flex flex-col justify-between min-h-[120px]">
            <div class="flex justify-between items-start">
              <span class="text-[9px] font-extrabold uppercase tracking-widest text-slate-400 dark:text-zinc-500">Logged today</span>
              <i data-lucide="zap" class="w-4 h-4 text-brand-orange shrink-0"></i>
            </div>
            <div class="mt-4">
              <span class="text-3xl font-extrabold text-slate-900 dark:text-white block"><%= metrics.followUpsLogged %></span>
              <span class="text-[9px] font-semibold text-slate-400 dark:text-zinc-500 uppercase tracking-wider block mt-1">Follow-ups logged</span>
            </div>
          </div>
        </div>

        <!-- Smart Suggestion Card -->
        <div class="bg-white dark:bg-brand-darkCard border border-slate-200/60 dark:border-brand-darkBorder rounded-3xl p-5 shadow-sm space-y-3">
          <span class="text-[9px] font-extrabold text-slate-400 dark:text-zinc-500 uppercase tracking-widest block">Smart Suggestion</span>
          <div class="bg-slate-50 dark:bg-brand-darkBg/60 rounded-xl p-4 border border-slate-100 dark:border-brand-darkBorder">
            <p class="text-xs text-slate-600 dark:text-zinc-400 leading-relaxed font-medium">
              Leads followed up within <span class="text-brand-orange dark:text-white font-bold">5 minutes</span> of inquiry have a <span class="text-brand-orange dark:text-brand-orange font-bold">4.2x higher conversion rate</span>. Try the "Call Now" button more today!
            </p>
          </div>
        </div>

      </div>

    </div>
    </div> <!-- Close listViewContainer -->

    <!-- Calendar View Container (Hidden by default) -->
    <div id="calendarViewContainer" class="hidden transition-opacity duration-300 bg-white dark:bg-brand-darkCard border border-slate-200/60 dark:border-brand-darkBorder rounded-3xl p-6 shadow-sm">
      <div id="calendar"></div>
    </div>

    <!-- Event Details Modal (Overlay) -->
    <div id="eventDetailsModal" class="fixed inset-0 z-50 flex items-center justify-center hidden">
      <!-- Backdrop -->
      <div id="modalBackdrop" class="absolute inset-0 bg-slate-900/60 dark:bg-black/80 backdrop-blur-sm opacity-0 transition-opacity duration-300"></div>
      
      <!-- Modal Content Container -->
      <div id="modalContent" class="bg-white dark:bg-brand-darkCard border border-slate-200/60 dark:border-brand-darkBorder rounded-3xl w-full max-w-lg mx-4 overflow-hidden shadow-2xl relative z-10 scale-95 opacity-0 transition-all duration-300 flex flex-col max-h-[90vh]">
        <!-- Modal Header -->
        <div class="px-6 py-5 border-b border-slate-100 dark:border-brand-darkBorder flex items-center justify-between">
          <div class="flex items-center gap-3">
            <div id="modalIconContainer" class="w-10 h-10 rounded-2xl flex items-center justify-center shrink-0">
              <i id="modalIcon" data-lucide="phone" class="w-5 h-5"></i>
            </div>
            <div>
              <span id="modalTypeBadge" class="text-[9px] font-extrabold px-2 py-0.5 rounded-full uppercase tracking-wider">Follow-Up</span>
              <h3 id="modalTitle" class="font-extrabold text-lg text-slate-900 dark:text-white mt-0.5">Event Title</h3>
            </div>
          </div>
          <button id="closeModalBtn" class="p-2 text-slate-400 hover:text-slate-600 dark:hover:text-white rounded-full hover:bg-slate-50 dark:hover:bg-brand-darkBg transition-all cursor-pointer">
            <i data-lucide="x" class="w-5 h-5"></i>
          </button>
        </div>
        
        <!-- Modal Body -->
        <div class="px-6 py-6 space-y-6 overflow-y-auto flex-1">
          <!-- Date/Time info -->
          <div class="flex items-center gap-3 text-sm font-semibold text-slate-700 dark:text-zinc-300">
            <i data-lucide="calendar" class="w-4 h-4 text-slate-400"></i>
            <span id="modalDateStr">Date & Time</span>
          </div>
          
          <!-- Customer Information Card -->
          <div class="bg-slate-50 dark:bg-brand-darkBg/60 border border-slate-100 dark:border-brand-darkBorder rounded-2xl p-4 space-y-3">
            <h4 class="text-[10px] font-extrabold text-slate-400 dark:text-zinc-500 uppercase tracking-widest">Customer Details</h4>
            <div class="grid grid-cols-2 gap-4 text-xs font-semibold">
              <div>
                <span class="text-[10px] text-slate-400 dark:text-zinc-500 block mb-0.5">Name</span>
                <span id="modalCustName" class="text-slate-800 dark:text-zinc-200">Customer Name</span>
              </div>
              <div>
                <span class="text-[10px] text-slate-400 dark:text-zinc-500 block mb-0.5">Phone</span>
                <span id="modalCustPhone" class="text-slate-800 dark:text-zinc-200">Customer Phone</span>
              </div>
              <div class="col-span-2">
                <span class="text-[10px] text-slate-400 dark:text-zinc-500 block mb-0.5">Email</span>
                <span id="modalCustEmail" class="text-slate-800 dark:text-zinc-200">Customer Email</span>
              </div>
            </div>
          </div>
          
          <!-- Description & Salesperson info -->
          <div class="space-y-4">
            <div id="modalDescContainer" class="space-y-1.5">
              <span class="text-[10px] font-extrabold text-slate-400 dark:text-zinc-500 uppercase tracking-widest block">Description / Notes</span>
              <p id="modalDesc" class="text-xs text-slate-600 dark:text-zinc-400 font-medium leading-relaxed italic">"Description goes here..."</p>
            </div>
            
            <div id="modalSalespersonContainer" class="space-y-1.5 hidden">
              <span class="text-[10px] font-extrabold text-slate-400 dark:text-zinc-500 uppercase tracking-widest block">Assigned Salesperson</span>
              <span id="modalSalesperson" class="text-xs font-semibold text-slate-800 dark:text-zinc-200 block">Salesperson Name</span>
            </div>
          </div>
          
          <!-- Reschedule Section -->
          <div id="modalRescheduleSection" class="border-t border-slate-100 dark:border-brand-darkBorder pt-5 space-y-3">
            <span class="text-[10px] font-extrabold text-slate-400 dark:text-zinc-500 uppercase tracking-widest block">Reschedule Follow-Up</span>
            <div class="flex items-center gap-3">
              <div class="relative flex-1">
                <input type="datetime-local" id="modalRescheduleDate" class="w-full text-xs font-bold bg-white dark:bg-brand-darkBg text-slate-800 dark:text-zinc-200 border border-slate-200 dark:border-brand-darkBorder rounded-xl px-4 py-2.5 outline-none focus:border-brand-orange dark:focus:border-brand-orange transition-colors" />
              </div>
              <button id="modalRescheduleBtn" class="bg-brand-orange hover:bg-orange-600 text-white font-bold text-xs px-4 py-2.5 rounded-xl transition-all cursor-pointer shadow-sm">
                Reschedule
              </button>
            </div>
          </div>

          <!-- Reassign Section -->
          <div id="modalReassignSection" class="border-t border-slate-100 dark:border-brand-darkBorder pt-5 space-y-3">
            <span class="text-[10px] font-extrabold text-slate-400 dark:text-zinc-500 uppercase tracking-widest block">Reassign Task</span>
            <div class="flex items-center gap-3">
              <div class="relative flex-1">
                <select id="modalReassignSelect" class="w-full text-xs font-bold bg-white dark:bg-brand-darkBg text-slate-800 dark:text-zinc-200 border border-slate-200 dark:border-brand-darkBorder rounded-xl px-4 py-2.5 outline-none focus:border-brand-orange dark:focus:border-brand-orange transition-colors">
                  <option value="">Select Salesperson...</option>
                  <% users.forEach(user => { %>
                    <option value="<%= user._id %>"><%= user.name %></option>
                  <% }) %>
                </select>
              </div>
              <button id="modalReassignBtn" class="bg-brand-orange hover:bg-orange-600 text-white font-bold text-xs px-4 py-2.5 rounded-xl transition-all cursor-pointer shadow-sm">
                Reassign
              </button>
            </div>
          </div>
        </div>
        
        <!-- Modal Footer / Actions -->
        <div id="modalFooter" class="px-6 py-4 border-t border-slate-100 dark:border-brand-darkBorder bg-slate-50/50 dark:bg-brand-darkBg/20 flex flex-wrap gap-2.5 items-center justify-between">
          <!-- Phone/Call icon link -->
          <div class="flex gap-2 font-sans">
            <a id="modalCallBtn" href="#" class="flex items-center gap-1.5 px-3.5 py-2.5 rounded-xl border border-slate-200 dark:border-brand-darkBorder bg-white dark:bg-brand-darkCard text-slate-600 hover:text-slate-900 dark:text-zinc-300 dark:hover:bg-zinc-800 text-xs font-bold transition-all">
              <i data-lucide="phone" class="w-3.5 h-3.5"></i>
              <span>Call Now</span>
            </a>
            <button id="modalSMSBtn" type="button" class="flex items-center gap-1.5 px-3.5 py-2.5 rounded-xl border border-slate-200 dark:border-brand-darkBorder bg-white dark:bg-brand-darkCard text-slate-600 hover:text-slate-900 dark:text-zinc-300 dark:hover:bg-zinc-800 text-xs font-bold transition-all cursor-pointer">
              <i data-lucide="message-square" class="w-3.5 h-3.5"></i>
              <span>Send SMS</span>
            </button>
          </div>
          
          <!-- Status Actions -->
          <div class="flex gap-2" id="modalStatusActions">
            <button id="modalMissedBtn" class="flex items-center gap-1.5 px-3.5 py-2.5 rounded-xl border border-rose-200 hover:bg-rose-50 dark:border-rose-950/40 dark:hover:bg-rose-950/20 text-rose-500 text-xs font-bold cursor-pointer transition-all">
              <i data-lucide="alert-circle" class="w-3.5 h-3.5"></i>
              <span>Mark Missed</span>
            </button>
            <button id="modalCompleteBtn" class="flex items-center gap-1.5 px-3.5 py-2.5 rounded-xl bg-brand-orange hover:bg-orange-600 text-white text-xs font-bold cursor-pointer transition-all shadow-sm">
              <i data-lucide="check" class="w-3.5 h-3.5"></i>
              <span>Complete Follow-Up</span>
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- Reassign All Modal (Overlay) -->
    <div id="reassignAllModal" class="fixed inset-0 z-50 flex items-center justify-center hidden">
      <!-- Backdrop -->
      <div id="reassignAllBackdrop" class="absolute inset-0 bg-slate-900/60 dark:bg-black/80 backdrop-blur-sm opacity-0 transition-opacity duration-300"></div>
      
      <!-- Modal Content Container -->
      <div id="reassignAllContent" class="bg-white dark:bg-brand-darkCard border border-slate-200/60 dark:border-brand-darkBorder rounded-3xl w-full max-w-md mx-4 overflow-hidden shadow-2xl relative z-10 scale-95 opacity-0 transition-all duration-300 flex flex-col">
        <!-- Modal Header -->
        <div class="px-6 py-5 border-b border-slate-100 dark:border-brand-darkBorder flex items-center justify-between">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-2xl flex items-center justify-center shrink-0 text-brand-orange bg-orange-50 dark:bg-orange-950/30">
              <i data-lucide="users" class="w-5 h-5"></i>
            </div>
            <div>
              <h3 class="font-extrabold text-lg text-slate-900 dark:text-white">Reassign All Overdue</h3>
              <p class="text-xs text-slate-500 dark:text-zinc-400">Reassign all pending and missed overdue tasks.</p>
            </div>
          </div>
          <button id="closeReassignAllBtn" class="p-2 text-slate-400 hover:text-slate-600 dark:hover:text-white rounded-full hover:bg-slate-50 dark:hover:bg-brand-darkBg transition-all cursor-pointer">
            <i data-lucide="x" class="w-5 h-5"></i>
          </button>
        </div>
        
        <!-- Modal Body -->
        <div class="px-6 py-6 space-y-4">
          <div class="space-y-1.5">
            <label class="text-[10px] font-extrabold text-slate-400 dark:text-zinc-500 uppercase tracking-widest block">Select New Salesperson</label>
            <select id="reassignAllSelect" class="w-full text-xs font-bold bg-white dark:bg-brand-darkBg text-slate-800 dark:text-zinc-200 border border-slate-200 dark:border-brand-darkBorder rounded-xl px-4 py-2.5 outline-none focus:border-brand-orange dark:focus:border-brand-orange transition-colors">
              <option value="">Select Salesperson...</option>
              <% users.forEach(user => { %>
                <option value="<%= user._id %>"><%= user.name %></option>
              <% }) %>
            </select>
          </div>
        </div>
        
        <!-- Modal Footer -->
        <div class="px-6 py-4 border-t border-slate-100 dark:border-brand-darkBorder bg-slate-50/50 dark:bg-brand-darkBg/20 flex gap-2.5 items-center justify-end">
          <button id="cancelReassignAllBtn" class="px-4 py-2 rounded-xl border border-slate-200 dark:border-brand-darkBorder text-slate-600 dark:text-zinc-300 text-xs font-bold hover:bg-slate-50 dark:hover:bg-zinc-800 transition-all cursor-pointer">
            Cancel
          </button>
          <button id="confirmReassignAllBtn" class="px-4 py-2 rounded-xl bg-brand-orange hover:bg-orange-600 text-white text-xs font-bold transition-all shadow-sm cursor-pointer">
            Confirm Reassign
          </button>
        </div>
      </div>
    </div>

    <!-- View All Missed Tasks Modal (Overlay) -->
    <div id="viewAllMissedModal" class="fixed inset-0 z-50 flex items-center justify-center hidden">
      <!-- Backdrop -->
      <div id="viewAllMissedBackdrop" class="absolute inset-0 bg-slate-900/60 dark:bg-black/80 backdrop-blur-sm opacity-0 transition-opacity duration-300"></div>
      
      <!-- Modal Content Container -->
      <div id="viewAllMissedContent" class="bg-white dark:bg-brand-darkCard border border-slate-200/60 dark:border-brand-darkBorder rounded-3xl w-full max-w-4xl mx-4 overflow-hidden shadow-2xl relative z-10 scale-95 opacity-0 transition-all duration-300 flex flex-col max-h-[85vh]">
        <!-- Modal Header -->
        <div class="px-6 py-5 border-b border-slate-100 dark:border-brand-darkBorder flex items-center justify-between">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-2xl flex items-center justify-center shrink-0 text-rose-500 bg-rose-50 dark:bg-rose-950/20">
              <i data-lucide="alert-triangle" class="w-5 h-5"></i>
            </div>
            <div>
              <h3 class="font-extrabold text-lg text-slate-900 dark:text-white">All Missed & Overdue Tasks</h3>
              <p class="text-xs text-slate-500 dark:text-zinc-400">Total overdue tasks: <span class="font-bold text-rose-500"><%= overdue.length %></span></p>
            </div>
          </div>
          <button id="closeViewAllMissedBtn" class="p-2 text-slate-400 hover:text-slate-600 dark:hover:text-white rounded-full hover:bg-slate-50 dark:hover:bg-brand-darkBg transition-all cursor-pointer">
            <i data-lucide="x" class="w-5 h-5"></i>
          </button>
        </div>
        
        <!-- Modal Body -->
        <div class="px-6 py-6 overflow-y-auto flex-1">
          <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
              <thead>
                <tr class="border-b border-slate-200 dark:border-brand-darkBorder text-[10px] font-extrabold uppercase tracking-widest text-slate-400 dark:text-zinc-500">
                  <th class="pb-3 pl-2">Customer Name</th>
                  <th class="pb-3">Phone Number</th>
                  <th class="pb-3">Assigned User</th>
                  <th class="pb-3">Due Date</th>
                  <th class="pb-3">Status</th>
                  <th class="pb-3 pr-2 text-right">Actions</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100 dark:divide-brand-darkBorder text-xs">
                <% if (overdue.length === 0) { %>
                  <tr>
                    <td colspan="6" class="py-8 text-center text-slate-400 dark:text-zinc-500 font-medium">No overdue or missed tasks.</td>
                  </tr>
                <% } else { %>
                  <% overdue.forEach(task => { %>
                    <tr class="hover:bg-slate-50/40 dark:hover:bg-brand-darkCard/40 transition-colors">
                      <td class="py-4 pl-2 font-bold text-slate-800 dark:text-zinc-200"><%= task.lead ? task.lead.name : 'Unknown' %></td>
                      <td class="py-4">
                        <% if (task.lead && task.lead.phone) { %>
                          <a href="tel:<%= task.lead.phone %>" data-task-id="<%= task._id %>" data-lead-id="<%= task.lead._id %>" class="text-brand-orange hover:underline font-semibold flex items-center gap-1">
                            <i data-lucide="phone" class="w-3.5 h-3.5 inline"></i>
                            <span><%= task.lead.phone %></span>
                          </a>
                        <% } else { %>
                          <span class="text-slate-400 dark:text-zinc-500">N/A</span>
                        <% } %>
                      </td>
                      <td class="py-4 font-semibold text-slate-600 dark:text-zinc-400"><%= task.assignedTo ? task.assignedTo.name : 'Unassigned' %></td>
                      <td class="py-4 text-slate-500 dark:text-zinc-500 font-medium"><%= new Date(task.dueDate).toLocaleDateString() %></td>
                      <td class="py-4">
                        <span class="px-2.5 py-0.5 text-[9px] font-extrabold rounded-full border bg-rose-50 text-rose-600 dark:bg-rose-950/30 dark:text-rose-400 border-rose-100">
                          <%= task.status %>
                        </span>
                      </td>
                      <td class="py-4 pr-2 text-right">
                        <div class="flex items-center justify-end gap-2">
                          <!-- Complete form -->
                          <form action="/follow-ups/done/<%= task._id %>" method="POST" class="inline">
                            <button type="submit" title="Mark Completed" class="p-1.5 rounded-lg bg-emerald-50 text-emerald-600 hover:bg-emerald-600 hover:text-white dark:bg-brand-darkBg dark:text-emerald-400 dark:hover:bg-emerald-950/20 flex items-center justify-center cursor-pointer transition-all">
                              <i data-lucide="check" class="w-3.5 h-3.5"></i>
                            </button>
                          </form>
                          <!-- Reschedule tomorrow -->
                          <form action="/follow-ups/reschedule/<%= task._id %>" method="POST" class="inline">
                            <input type="hidden" name="newDate" value="<%= nextDay %>" />
                            <button type="submit" title="Reschedule to Tomorrow" class="p-1.5 rounded-lg bg-blue-50 text-brand-orange hover:bg-brand-orange hover:text-white dark:bg-brand-darkBg dark:text-orange-400 dark:hover:bg-orange-950/20 flex items-center justify-center cursor-pointer transition-all">
                              <i data-lucide="calendar" class="w-3.5 h-3.5"></i>
                            </button>
                          </form>
                        </div>
                      </td>
                    </tr>
                  <% }) %>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
        
        <!-- Modal Footer -->
        <div class="px-6 py-4 border-t border-slate-100 dark:border-brand-darkBorder bg-slate-50/50 dark:bg-brand-darkBg/20 flex items-center justify-end">
          <button id="cancelViewAllMissedBtn" class="px-5 py-2.5 rounded-xl border border-slate-200 dark:border-brand-darkBorder text-slate-600 dark:text-zinc-300 text-xs font-bold hover:bg-slate-50 dark:hover:bg-zinc-800 transition-all cursor-pointer">
            Close
          </button>
        </div>
      </div>
    </div>

    <!-- Load FullCalendar CSS and JS from CDN -->
    <link href='https://cdn.jsdelivr.net/npm/fullcalendar@6.1.15/index.global.min.css' rel='stylesheet' />
    <script src='https://cdn.jsdelivr.net/npm/fullcalendar@6.1.15/index.global.min.js'></script>
    
