<!-- Scripts for tab switching and dynamic controls -->
<script>
  // Avatar preview functionality
  function updateAvatarPreview(url) {
    const container = document.getElementById('profile-avatar-container');
    if (!container) return;
    if (url && (url.startsWith('http://') || url.startsWith('https://') || url.startsWith('/'))) {
      container.innerHTML = `<img src="${url}" alt="Avatar" class="w-16 h-16 rounded-full object-cover border border-slate-200 dark:border-brand-darkBorder shadow-sm" id="profile-avatar-preview" />`;
    } else {
      const nameInput = document.querySelector('input[name="name"]');
      const name = nameInput ? nameInput.value : 'User';
      const initials = name.split(' ').map(n => n[0]).join('').toUpperCase().substring(0, 2) || 'U';
      container.innerHTML = `<div class="w-16 h-16 rounded-full bg-slate-900 text-white dark:bg-brand-orange font-bold text-lg flex items-center justify-center border border-slate-200 dark:border-brand-darkBorder shadow-sm animate-fade-in" id="profile-avatar-preview">${initials}</div>`;
    }
  }

  // Tab switching functionality with smooth transitions
  function switchTab(tabId) {
    // Hide all panels
    document.querySelectorAll('.settings-panel').forEach(panel => {
      panel.classList.add('hidden');
      panel.classList.remove('transition-all', 'duration-300', 'ease-out', 'opacity-100', 'translate-y-0', 'opacity-0', 'translate-y-2');
    });
    
    // Show selected panel with smooth transition
    const selectedPanel = document.getElementById(`panel-${tabId}`);
    if (selectedPanel) {
      selectedPanel.classList.add('opacity-0', 'translate-y-2');
      selectedPanel.classList.remove('hidden');
      
      // Force repaint to register initial state
      selectedPanel.offsetHeight;
      
      selectedPanel.classList.add('transition-all', 'duration-300', 'ease-out', 'opacity-100', 'translate-y-0');
      selectedPanel.classList.remove('opacity-0', 'translate-y-2');
    }
    
    // Update tab button styles
    document.querySelectorAll('.settings-tab').forEach(tab => {
      tab.classList.remove('bg-white', 'border-2', 'border-brand-orange', 'text-brand-orange', 'dark:text-white');
      tab.classList.add('bg-white', 'hover:bg-slate-50', 'border', 'border-slate-200/60', 'text-slate-700', 'dark:text-zinc-300');
    });
    
    const selectedTab = document.getElementById(`tab-${tabId}`);
    if (selectedTab) {
      selectedTab.classList.remove('bg-white', 'hover:bg-slate-50', 'border', 'border-slate-200/60', 'text-slate-700', 'dark:text-zinc-300');
      selectedTab.classList.add('bg-white', 'border-2', 'border-brand-orange', 'text-brand-orange', 'dark:text-white');
    }
    
    // Update URL without page reload
    history.pushState(null, '', `?tab=${tabId}`);
  }
  
  // Initialize tab from URL or default
  (function() {
    function initSettingsTab() {
      const urlParams = new URLSearchParams(window.location.search);
      const initialTab = urlParams.get('tab') || 'my-profile';
      switchTab(initialTab);

      // Show success/error messages if present
      const urlParams2 = new URLSearchParams(window.location.search);
      if (urlParams2.get('success')) {
        const successType = urlParams2.get('success');
        let message = 'Settings saved successfully!';
        if (successType === 'profile') message = 'Dealership profile updated successfully!';
        if (successType === 'profile_updated') message = 'Your profile has been updated successfully!';
        if (successType === 'crm') message = 'CRM configuration updated successfully!';
        if (successType === 'security') message = 'Security settings updated successfully!';
        showToast(message, 'success');
        // Clean URL
        history.replaceState(null, '', '/settings?tab=' + initialTab);
      }
      if (urlParams2.get('error')) {
        const errorType = urlParams2.get('error');
        let message = 'Error saving settings. Please try again.';
        if (errorType === 'validation') message = 'Please check your input and try again.';
        if (errorType === 'profile') message = 'Error updating dealership profile. Please try again.';
        if (errorType === 'profile_failed') message = 'Error updating your profile. Please try again.';
        if (errorType === 'exists') message = 'Email address is already in use by another user.';
        if (errorType === 'crm') message = 'Error updating CRM configuration. Please try again.';
        if (errorType === 'security') message = 'Error updating security settings. Please try again.';
        showToast(message, 'error');
        // Clean URL
        history.replaceState(null, '', '/settings?tab=' + initialTab);
      }

      // Sync pipelineStages input changes with Default Lead Status select options
      const stagesInput = document.querySelector('input[name="pipelineStages"]');
      const statusSelect = document.querySelector('select[name="defaultLeadStatus"]');
      
      if (stagesInput && statusSelect) {
        stagesInput.addEventListener('input', () => {
          const val = stagesInput.value;
          const stages = val.split(',').map(s => s.trim()).filter(Boolean);
          const currentSelected = statusSelect.value;
          statusSelect.innerHTML = '';
          
          stages.forEach(stg => {
            const opt = document.createElement('option');
            opt.value = stg;
            opt.textContent = stg;
            if (stg === currentSelected) {
              opt.selected = true;
            }
            statusSelect.appendChild(opt);
          });
          
          if (!statusSelect.value && stages.length > 0) {
            statusSelect.value = stages[0];
          }
        });
      }

      // Re-initialize Lucide icons
      if (typeof lucide !== 'undefined') {
        lucide.createIcons();
      }

      // AJAX Form Submission for all settings forms
      const forms = ['form-my-profile', 'form-dealership-profile', 'form-crm-config', 'form-security', 'form-notifications'];
      forms.forEach(formId => {
        const form = document.getElementById(formId);
        if (form) {
          form.addEventListener('submit', async (e) => {
            e.preventDefault();
            const formData = new FormData(form);
            const searchParams = new URLSearchParams(formData);
            const submitBtn = form.querySelector('button[type="submit"]');
            const originalText = submitBtn.textContent;
            submitBtn.textContent = 'Saving...';
            submitBtn.disabled = true;

            try {
              const response = await fetch(form.action, {
                method: 'POST',
                headers: {
                  'Content-Type': 'application/x-www-form-urlencoded',
                  'X-Requested-With': 'XMLHttpRequest',
                  'Accept': 'application/json'
                },
                body: searchParams.toString()
              });

              const data = await response.json();

              if (data.success) {
                showToast(data.message || 'Settings saved successfully!', 'success');
              } else if (data.errors) {
                // Handle validation errors
                const errorMessages = data.errors.map(err => err.message).join(', ');
                showToast(errorMessages || 'Please check your input and try again.', 'error');
              } else {
                showToast(data.message || 'Error saving settings. Please try again.', 'error');
              }
            } catch (error) {
              console.error('Form submission error:', error);
              showToast('Error saving settings. Please try again.', 'error');
            } finally {
              submitBtn.textContent = originalText;
              submitBtn.disabled = false;
            }
          });
        }
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initSettingsTab);
    } else {
      initSettingsTab();
    }
  })();
  
  async function toggleConfig(category, name) {
    try {
      const response = await fetch(`/settings/${category}/${name}`, { method: 'POST' });
      const data = await response.json();
      
      if (data.success) {
        if (category === 'notifications') {
          const isEnabled = data.notifications[name];
          const statusText = document.getElementById(`${name}-status-text`);
          const toggleDot = document.getElementById(`${name}-toggle-dot`);
          const toggleBtn = toggleDot.parentElement;

          statusText.innerText = isEnabled ? 'Enabled' : 'Disabled';
          
          if (isEnabled) {
            toggleBtn.className = "w-10 h-6 rounded-full p-1 cursor-pointer transition-colors bg-brand-orange";
            toggleDot.className = "w-4 h-4 bg-white rounded-full transition-transform translate-x-4";
          } else {
            toggleBtn.className = "w-10 h-6 rounded-full p-1 cursor-pointer transition-colors bg-slate-200 dark:bg-zinc-700";
            toggleDot.className = "w-4 h-4 bg-white rounded-full transition-transform translate-x-0";
          }
          showToast('Notification preference updated', 'success');
        } else if (category === 'integrations') {
          const isEnabled = data.integrations[name];
          const badge = document.getElementById(`${name}-badge`);
          
          if (name === 'googleCalendar') {
            const btn = badge.nextElementSibling;
            if (isEnabled) {
              badge.className = "px-2 py-0.5 text-[9px] font-extrabold bg-emerald-50 text-emerald-600 dark:bg-emerald-950/30 dark:text-emerald-400 rounded uppercase tracking-wider";
              badge.innerText = "CONNECTED";
              btn.innerText = "Disconnect";
            } else {
              badge.className = "px-2 py-0.5 text-[9px] font-extrabold bg-slate-100 text-slate-500 dark:bg-zinc-800 dark:text-zinc-400 rounded uppercase tracking-wider";
              badge.innerText = "DISCONNECTED";
              btn.innerText = "Connect";
            }
          } else if (name === 'whatsapp') {
            const btn = document.getElementById('whatsapp-connect-btn');
            if (isEnabled) {
              badge.className = "px-2 py-0.5 text-[9px] font-extrabold bg-emerald-50 text-emerald-600 dark:bg-emerald-950/30 dark:text-emerald-400 rounded uppercase tracking-wider";
              badge.innerText = "CONNECTED";
              btn.className = "text-xs text-slate-400 hover:text-slate-600 dark:hover:text-white font-semibold cursor-pointer underline";
              btn.innerText = "Disconnect";
            } else {
              badge.className = "px-2 py-0.5 text-[9px] font-extrabold bg-slate-100 text-slate-500 dark:bg-zinc-800 dark:text-zinc-400 rounded uppercase tracking-wider";
              badge.innerText = "DISCONNECTED";
              btn.className = "text-xs text-brand-orange hover:underline font-bold cursor-pointer";
              btn.innerText = "Connect";
            }
          }
          showToast('Integration status updated', 'success');
        }
      }
    } catch (err) {
      console.error('Error toggling config:', err.message);
      showToast('Error updating setting', 'error');
    }
  }

  function toggleSwitch(id) {
    const input = document.getElementById(`input-${id}`);
    const btn = document.getElementById(`btn-${id}`);
    const dot = document.getElementById(`dot-${id}`);
    const textSpan = document.getElementById(`text-${id}`);
    
    if (input.value === 'true') {
      input.value = 'false';
      btn.className = "w-10 h-6 rounded-full p-1 cursor-pointer transition-all duration-300 ease-in-out bg-slate-200 dark:bg-zinc-700";
      dot.className = "w-4 h-4 bg-white rounded-full transition-all duration-300 ease-in-out translate-x-0";
      if (textSpan) textSpan.innerText = 'Disabled';
    } else {
      input.value = 'true';
