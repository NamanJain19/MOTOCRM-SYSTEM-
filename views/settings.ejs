  // User checkbox and bulk delete functionality
  (function() {
    const selectUsersBtn = document.getElementById('select-users-btn');
    const cancelSelectionBtn = document.getElementById('cancel-selection-btn');
    const bulkActionsContainer = document.getElementById('bulk-actions-container');
    const selectAllUsers = document.getElementById('select-all-users');
    const bulkDeleteUsersBtn = document.getElementById('bulk-delete-users-btn');
    const table = document.querySelector('table');
    const thead = table?.querySelector('thead tr');
    const tbody = table?.querySelector('tbody');
    const userRows = document.querySelectorAll('.user-row');

    function enterSelectionMode() {
      selectUsersBtn.classList.add('hidden');
      bulkActionsContainer.classList.remove('hidden');
      
      // Add checkbox column to header
      if (thead) {
        const checkboxHeader = document.createElement('th');
        checkboxHeader.className = 'py-3 px-2 text-center w-12';
        checkboxHeader.innerHTML = '';
        thead.insertBefore(checkboxHeader, thead.firstChild);
      }
      
      // Add checkbox to each row
      userRows.forEach(row => {
        const userId = row.getAttribute('data-user-id');
        const checkboxCell = document.createElement('td');
        checkboxCell.className = 'py-4 text-center';
        checkboxCell.innerHTML = `<input type="checkbox" class="user-checkbox w-4 h-4 rounded border-slate-300 dark:border-brand-darkBorder text-brand-orange focus:ring-brand-orange bg-slate-50 dark:bg-brand-darkBg cursor-pointer accent-brand-orange" value="${userId}" />`;
        row.insertBefore(checkboxCell, row.firstChild);
      });
      
      // Re-attach event listeners to new checkboxes
      const userCheckboxes = document.querySelectorAll('.user-checkbox');
      userCheckboxes.forEach(cb => {
        cb.addEventListener('change', function() {
          const allChecked = Array.from(userCheckboxes).every(c => c.checked);
          if (selectAllUsers) selectAllUsers.checked = allChecked;
          updateBulkDeleteButton();
        });
      });
      
      lucide.createIcons();
    }

    function exitSelectionMode() {
      selectUsersBtn.classList.remove('hidden');
      bulkActionsContainer.classList.add('hidden');
      
      // Remove checkbox column from header
      if (thead && thead.firstChild) {
        thead.removeChild(thead.firstChild);
      }
      
      // Remove checkbox from each row
      userRows.forEach(row => {
        if (row.firstChild) {
          row.removeChild(row.firstChild);
        }
      });
      
      // Reset select all and delete button
      if (selectAllUsers) selectAllUsers.checked = false;
      bulkDeleteUsersBtn.classList.add('hidden');
      bulkDeleteUsersBtn.querySelector('span').textContent = 'Delete Selected';
      
      lucide.createIcons();
    }

    function updateBulkDeleteButton() {
      const checkedCount = document.querySelectorAll('.user-checkbox:checked').length;
      if (checkedCount > 0) {
        bulkDeleteUsersBtn.classList.remove('hidden');
        bulkDeleteUsersBtn.querySelector('span').textContent = `Delete Selected (${checkedCount})`;
      } else {
        bulkDeleteUsersBtn.classList.add('hidden');
      }
    }

    if (selectUsersBtn) {
      selectUsersBtn.addEventListener('click', enterSelectionMode);
    }

    if (cancelSelectionBtn) {
      cancelSelectionBtn.addEventListener('click', exitSelectionMode);
    }

    if (selectAllUsers) {
      selectAllUsers.addEventListener('change', function() {
        const userCheckboxes = document.querySelectorAll('.user-checkbox');
        userCheckboxes.forEach(cb => cb.checked = this.checked);
        updateBulkDeleteButton();
      });
    }

    if (bulkDeleteUsersBtn) {
      bulkDeleteUsersBtn.addEventListener('click', async (e) => {
        e.preventDefault();
        
        const checkedBoxes = document.querySelectorAll('.user-checkbox:checked');
        const ids = Array.from(checkedBoxes).map(cb => cb.value);

        if (ids.length === 0) return;

        bulkDeleteUsersBtn.disabled = true;
        bulkDeleteUsersBtn.innerHTML = 'Deleting...';

        try {
          const res = await fetch('/settings/users/bulk-delete', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              'Accept': 'application/json'
            },
            body: JSON.stringify({ ids })
          });
          
          if (!res.ok) {
            const errorText = await res.text();
            throw new Error(`HTTP ${res.status}: ${errorText}`);
          }
          
          const data = await res.json();
          if (data.success) {
            showToast(data.message, 'success');
            setTimeout(() => {
              window.location.reload();
            }, 1000);
          } else {
            showToast(data.message || 'Error deleting users.', 'error');
            bulkDeleteUsersBtn.disabled = false;
            bulkDeleteUsersBtn.innerHTML = '<i data-lucide="trash-2" class="w-3.5 h-3.5"></i><span>Delete Selected</span>';
            lucide.createIcons();
          }
        } catch (err) {
          console.error(err);
          showToast('Connection error. Please try again.', 'error');
          bulkDeleteUsersBtn.disabled = false;
          bulkDeleteUsersBtn.innerHTML = '<i data-lucide="trash-2" class="w-3.5 h-3.5"></i><span>Delete Selected</span>';
          lucide.createIcons();
        }
      });
    }
  })();

  function handleAvatarUpload(input) {
    if (input.files && input.files[0]) {
      const file = input.files[0];
      
      const allowedTypes = ['image/png', 'image/jpeg', 'image/webp'];
      if (!allowedTypes.includes(file.type)) {
        alert('Only JPG, PNG and WEBP file formats are allowed.');
        input.value = '';
        return;
      }

      const maxSize = 2 * 1024 * 1024; // 2MB
      if (file.size > maxSize) {
        alert('Profile image size must be less than 2MB.');
        input.value = '';
        return;
      }

      const reader = new FileReader();
      reader.onload = function(e) {
        const base64Str = e.target.result;
        document.getElementById('my-profile-avatar-input').value = base64Str;
        
        const previewContainer = document.getElementById('profile-avatar-container');
        previewContainer.innerHTML = `<img src="${base64Str}" alt="Avatar" class="w-20 h-20 rounded-full object-cover border border-slate-200 dark:border-brand-darkBorder shadow-sm" id="profile-avatar-preview" />`;
      };
      reader.readAsDataURL(file);
    }
  }

  function clearProfileAvatar() {
    document.getElementById('my-profile-avatar-input').value = '';
    document.getElementById('my-profile-avatar-file').value = '';
    
    const userName = "<%= locals.user ? locals.user.name : '' %>";
    const initials = userName ? userName.split(' ').map(n => n[0]).join('').toUpperCase().substring(0, 2) : 'U';
    
    const previewContainer = document.getElementById('profile-avatar-container');
    previewContainer.innerHTML = `
      <div class="w-20 h-20 rounded-full bg-slate-900 text-white dark:bg-brand-orange font-bold text-xl flex items-center justify-center border border-slate-200 dark:border-brand-darkBorder shadow-sm animate-fade-in" id="profile-avatar-preview">
        ${initials}
      </div>
    `;
  }

  function viewUser(id, name, email, phone, role, status, avatar) {
    const modal = document.getElementById('view-user-modal');
    document.getElementById('view-user-name').textContent = name;
    document.getElementById('view-user-email').textContent = email;
    document.getElementById('view-user-phone').textContent = phone || 'N/A';
    document.getElementById('view-user-role-badge').textContent = role;
    
    const statusSpan = document.getElementById('view-user-status');
    const colorBg = status === 'Active' ? 'bg-emerald-500' : 'bg-rose-500';
    statusSpan.innerHTML = `<span class="w-2 h-2 rounded-full ${colorBg}"></span> ${status}`;
    
    const avatarEl = document.getElementById('view-user-avatar');
    if (avatar && avatar.trim() !== '') {
      avatarEl.innerHTML = `<img src="${avatar}" alt="Avatar" class="w-full h-full rounded-full object-cover" />`;
      avatarEl.className = "w-16 h-16 rounded-full border border-slate-200 dark:border-brand-darkBorder shadow-sm mb-2.5 overflow-hidden";
    } else {
      const initials = name.split(' ').map(n => n[0]).join('').toUpperCase().substring(0, 2);
      avatarEl.textContent = initials;
      avatarEl.className = "w-16 h-16 rounded-full bg-slate-900 text-white dark:bg-brand-orange font-bold text-lg flex items-center justify-center mb-2.5";
    }
    
    modal.classList.remove('hidden');
    modal.classList.add('flex');
  }
  
  function closeViewUserModal() {
    const modal = document.getElementById('view-user-modal');
    modal.classList.add('hidden');
    modal.classList.remove('flex');
  }

  function editUser(id, name, phone) {
    const modal = document.getElementById('edit-user-modal');
    const form = document.getElementById('form-edit-user');
    form.action = `/settings/users/edit/${id}`;
    
    document.getElementById('edit-user-name-input').value = name;
    document.getElementById('edit-user-phone-input').value = phone || '';
    
    modal.classList.remove('hidden');
    modal.classList.add('flex');
  }
  
  function closeEditUserModal() {
    const modal = document.getElementById('edit-user-modal');
    modal.classList.add('hidden');
    modal.classList.remove('flex');
  }

  function changeRole(id, name, role) {
    const modal = document.getElementById('change-role-modal');
    const form = document.getElementById('form-change-role');
    form.action = `/settings/users/change-role/${id}`;
    
    document.getElementById('change-role-user-name').textContent = `Configure access level for ${name}.`;
    document.getElementById('change-role-select').value = role;
    
    modal.classList.remove('hidden');
    modal.classList.add('flex');
  }
  
  function closeChangeRoleModal() {
    const modal = document.getElementById('change-role-modal');
    modal.classList.add('hidden');
    modal.classList.remove('flex');
  }

  function toggleStatus(id, name, currentStatus) {
    const newStatus = currentStatus === 'Active' ? 'Inactive' : 'Active';
    showConfirmModal(`Are you sure you want to change the status of ${name} to ${newStatus}?`, async () => {
      try {
        const response = await fetch(`/settings/users/toggle-status/${id}`, {
          method: 'POST',
          headers: {
            'X-Requested-With': 'XMLHttpRequest',
            'Accept': 'application/json'
          }
        });
        const data = await response.json();
        if (data.success) {
          showToast(data.message, 'success');
          setTimeout(() => {
            window.location.href = '/settings?tab=user-management';
          }, 1000);
        } else {
          showToast(data.message || 'Error updating status', 'error');
        }
      } catch (err) {
        console.error('Toggle status error:', err);
        showToast('Error updating status', 'error');
      }
    });
  }

  function deleteUser(id, name) {
    try {
      const response = fetch(`/settings/users/delete/${id}`, {
        method: 'POST',
        headers: {
          'X-Requested-With': 'XMLHttpRequest',
          'Accept': 'application/json'
        }
      });
      response.then(res => res.json()).then(data => {
        if (data.success) {
          showToast(data.message, 'success');
          // Remove the row from DOM without page reload
          const row = document.querySelector(`button[onclick*="deleteUser('${id}'"]`).closest('tr');
          if (row) {
            row.remove();
          }
          // Close dropdown
          closeAllUserDropdowns();
        } else {
          showToast(data.message || 'Error deleting user', 'error');
        }
      }).catch(err => {
        console.error('Delete user error:', err);
        showToast('Error deleting user', 'error');
      });
    } catch (err) {
      console.error('Delete user error:', err);
      showToast('Error deleting user', 'error');
    }
  }

  // --- AJAX User Form Submissions ---
  (function() {
    function initSettingsUserForms() {
      // Invite member form submit
      const inviteForm = document.getElementById('form-invite-user');
      if (inviteForm) {
        inviteForm.addEventListener('submit', async (e) => {
          e.preventDefault();
          const formData = new FormData(inviteForm);
          const searchParams = new URLSearchParams(formData);
          const submitBtn = inviteForm.querySelector('button[type="submit"]');
          const originalText = submitBtn.textContent;
          submitBtn.textContent = 'Inviting...';
          submitBtn.disabled = true;

          try {
            const response = await fetch(inviteForm.action, {
              method: 'POST',
              headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
                'X-Requested-With': 'XMLHttpRequest',
                'Accept': 'application/json'
              },
              body: searchParams.toString()
            });

            const data = await response.json();
            if (data.success) {
              closeInviteModal();
              showToast(data.message || 'Member invited successfully!', 'success');
              setTimeout(() => {
                window.location.href = '/settings?tab=user-management';
              }, 1000);
            } else {
              showToast(data.message || 'Error inviting member. Please try again.', 'error');
            }
          } catch (error) {
            console.error('Invite error:', error);
            showToast('Error inviting member. Please try again.', 'error');
          } finally {
            submitBtn.textContent = originalText;
            submitBtn.disabled = false;
          }
        });
      }

      // Edit and Change Role form submits
      ['form-edit-user', 'form-change-role'].forEach(formId => {
        const form = document.getElementById(formId);
        if (form) {
          form.addEventListener('submit', async (e) => {
            e.preventDefault();
            const formData = new FormData(form);
            const searchParams = new URLSearchParams(formData);
            const submitBtn = form.querySelector('button[type="submit"]');
            const originalText = submitBtn.textContent;
            submitBtn.textContent = 'Saving...';
            submitBtn.disabled = true;

            try {
              const response = await fetch(form.action, {
                method: 'POST',
                headers: {
                  'Content-Type': 'application/x-www-form-urlencoded',
                  'X-Requested-With': 'XMLHttpRequest',
                  'Accept': 'application/json'
                },
                body: searchParams.toString()
              });

              const data = await response.json();
              if (data.success) {
                if (formId === 'form-edit-user') closeEditUserModal();
                if (formId === 'form-change-role') closeChangeRoleModal();
                showToast(data.message || 'Updated successfully!', 'success');
                setTimeout(() => {
                  window.location.href = '/settings?tab=user-management';
                }, 1000);
              } else {
                showToast(data.message || 'Error saving changes. Please try again.', 'error');
              }
            } catch (error) {
              console.error('Error saving user change:', error);
              showToast('Error saving changes. Please try again.', 'error');
            } finally {
              submitBtn.textContent = originalText;
              submitBtn.disabled = false;
            }
          });
        }
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initSettingsUserForms);
    } else {
      initSettingsUserForms();
    }
  })();
</script>

