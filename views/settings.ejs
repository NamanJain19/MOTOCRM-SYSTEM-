<%- include('partials/head') %>

<!-- Narrow Sidebar -->
<%- include('partials/sidebar') %>

<!-- Main Wrapper -->
<div class="flex-1 flex flex-col min-w-0 transition-colors duration-200 bg-brand-lightBg dark:bg-brand-darkBg">
  <!-- Header -->
  <%- include('partials/header') %>

  <!-- Content Container (Split Layout) -->
  <main class="flex-1 overflow-y-auto p-8 grid grid-cols-1 lg:grid-cols-[18rem_1fr] gap-8">
    
    <!-- Left Column (Sub-navigation tabs) -->
    <div class="w-full lg:w-72 shrink-0 space-y-4">
      <h2 class="text-xs font-extrabold text-slate-400 dark:text-zinc-500 uppercase tracking-widest pl-2">Settings Menu</h2>
      <div class="flex flex-col gap-2">
        <button 
          onclick="switchTab('my-profile')" 
          id="tab-my-profile"
          class="settings-tab flex items-center justify-between px-5 py-4 bg-white border-2 border-brand-orange rounded-2xl shadow-sm text-brand-orange font-bold text-sm dark:bg-brand-darkCard dark:border-brand-darkBorder dark:text-white transition-all"
        >
          <span class="flex items-center gap-2.5">
            <i data-lucide="user" class="w-4 h-4"></i>
            My Profile
          </span>
          <i data-lucide="chevron-right" class="w-4 h-4 opacity-75"></i>
        </button>
        <button 
          onclick="switchTab('dealership-profile')" 
          id="tab-dealership-profile"
          class="settings-tab flex items-center justify-between px-5 py-4 bg-white hover:bg-slate-50 border border-slate-200/60 rounded-2xl shadow-sm text-slate-700 font-semibold text-sm dark:bg-brand-darkCard dark:border-brand-darkBorder dark:text-zinc-300 dark:hover:bg-zinc-800 transition-all"
        >
          <span class="flex items-center gap-2.5">
            <i data-lucide="building-2" class="w-4 h-4 text-slate-400"></i>
            Dealership Profile
          </span>
          <i data-lucide="chevron-right" class="w-4 h-4 text-slate-400"></i>
        </button>
        <button 
          onclick="switchTab('user-management')" 
          id="tab-user-management"
          class="settings-tab flex items-center justify-between px-5 py-4 bg-white hover:bg-slate-50 border border-slate-200/60 rounded-2xl shadow-sm text-slate-700 font-semibold text-sm dark:bg-brand-darkCard dark:border-brand-darkBorder dark:text-zinc-300 dark:hover:bg-zinc-800 transition-all"
        >
          <span class="flex items-center gap-2.5">
            <i data-lucide="users" class="w-4 h-4 text-slate-400"></i>
            User Management
          </span>
          <i data-lucide="chevron-right" class="w-4 h-4 text-slate-400"></i>
        </button>
        <button 
          onclick="switchTab('crm-configurations')" 
          id="tab-crm-configurations"
          class="settings-tab flex items-center justify-between px-5 py-4 bg-white hover:bg-slate-50 border border-slate-200/60 rounded-2xl shadow-sm text-slate-700 font-semibold text-sm dark:bg-brand-darkCard dark:border-brand-darkBorder dark:text-zinc-300 dark:hover:bg-zinc-800 transition-all"
        >
          <span class="flex items-center gap-2.5">
            <i data-lucide="sliders" class="w-4 h-4 text-slate-400"></i>
            CRM Configurations
          </span>
          <i data-lucide="chevron-right" class="w-4 h-4 text-slate-400"></i>
        </button>
        <button 
          onclick="switchTab('notifications')" 
          id="tab-notifications"
          class="settings-tab flex items-center justify-between px-5 py-4 bg-white hover:bg-slate-50 border border-slate-200/60 rounded-2xl shadow-sm text-slate-700 font-semibold text-sm dark:bg-brand-darkCard dark:border-brand-darkBorder dark:text-zinc-300 dark:hover:bg-zinc-800 transition-all"
        >
          <span class="flex items-center gap-2.5">
            <i data-lucide="bell" class="w-4 h-4 text-slate-400"></i>
            Notifications
          </span>
          <i data-lucide="chevron-right" class="w-4 h-4 text-slate-400"></i>
        </button>
        <button 
          onclick="switchTab('integrations')" 
          id="tab-integrations"
          class="settings-tab flex items-center justify-between px-5 py-4 bg-white hover:bg-slate-50 border border-slate-200/60 rounded-2xl shadow-sm text-slate-700 font-semibold text-sm dark:bg-brand-darkCard dark:border-brand-darkBorder dark:text-zinc-300 dark:hover:bg-zinc-800 transition-all"
        >
          <span class="flex items-center gap-2.5">
            <i data-lucide="link" class="w-4 h-4 text-slate-400"></i>
            Integrations
          </span>
          <i data-lucide="chevron-right" class="w-4 h-4 text-slate-400"></i>
        </button>
        <button 
          onclick="switchTab('security')" 
          id="tab-security"
          class="settings-tab flex items-center justify-between px-5 py-4 bg-white hover:bg-slate-50 border border-slate-200/60 rounded-2xl shadow-sm text-slate-700 font-semibold text-sm dark:bg-brand-darkCard dark:border-brand-darkBorder dark:text-zinc-300 dark:hover:bg-zinc-800 transition-all"
        >
          <span class="flex items-center gap-2.5">
            <i data-lucide="shield" class="w-4 h-4 text-slate-400"></i>
            Security
          </span>
          <i data-lucide="chevron-right" class="w-4 h-4 text-slate-400"></i>
        </button>
        <button 
          onclick="switchTab('theme-settings')" 
          id="tab-theme-settings"
          class="settings-tab flex items-center justify-between px-5 py-4 bg-white hover:bg-slate-50 border border-slate-200/60 rounded-2xl shadow-sm text-slate-700 font-semibold text-sm dark:bg-brand-darkCard dark:border-brand-darkBorder dark:text-zinc-300 dark:hover:bg-zinc-800 transition-all"
        >
          <span class="flex items-center gap-2.5">
            <i data-lucide="palette" class="w-4 h-4 text-slate-400"></i>
            Theme Settings
          </span>
          <i data-lucide="chevron-right" class="w-4 h-4 text-slate-400"></i>
        </button>
      </div>
    </div>

    <!-- Right Column (Content Panels) -->
    <div class="flex-1 max-w-4xl">
      
      <!-- Panel: My Profile -->
      <section id="panel-my-profile" class="settings-panel bg-white dark:bg-brand-darkCard border border-slate-200/60 dark:border-brand-darkBorder rounded-3xl shadow-sm overflow-hidden">
        <form id="form-my-profile" action="/settings/my-profile" method="POST">
          <div class="px-6 py-4 border-b border-slate-100 dark:border-brand-darkBorder flex items-center justify-between bg-slate-50/50 dark:bg-brand-darkBg/50">
            <div class="flex items-center gap-3">
              <i data-lucide="user" class="w-5 h-5 text-brand-orange"></i>
              <div>
                <h3 class="font-bold text-base text-slate-900 dark:text-white">My Profile</h3>
                <p class="text-xs text-slate-400 dark:text-zinc-500">Update your personal account details, contact info, and profile avatar.</p>
              </div>
            </div>
            <button type="submit" class="px-4 py-2 rounded-2xl text-xs font-bold bg-brand-orange hover:bg-orange-600 text-white cursor-pointer transition-all">
              Save Changes
            </button>
          </div>

          <div class="p-6 space-y-6">
            <!-- Avatar Section -->
            <div class="flex items-center gap-5 pb-4 border-b border-slate-150 dark:border-brand-darkBorder/40 font-sans">
              <div id="profile-avatar-container" class="relative group shrink-0">
                <% if (locals.user && locals.user.avatar) { %>
                  <img src="<%= locals.user.avatar %>" alt="Avatar" class="w-20 h-20 rounded-full object-cover border border-slate-200 dark:border-brand-darkBorder shadow-sm" id="profile-avatar-preview" />
                <% } else { %>
                  <div class="w-20 h-20 rounded-full bg-slate-900 text-white dark:bg-brand-orange font-bold text-xl flex items-center justify-center border border-slate-200 dark:border-brand-darkBorder shadow-sm animate-fade-in" id="profile-avatar-preview">
                    <%= locals.user ? locals.user.name.split(' ').map(n => n[0]).join('').toUpperCase().substring(0, 2) : 'U' %>
                  </div>
                <% } %>
              </div>
              <div class="space-y-2">
                <label class="text-[10px] font-extrabold text-slate-400 dark:text-zinc-555 uppercase tracking-wider block">Profile Picture</label>
                <div class="flex items-center gap-3">
                  <button type="button" onclick="document.getElementById('my-profile-avatar-file').click()" class="px-4 py-2.5 bg-slate-900 hover:bg-slate-800 text-white dark:bg-white dark:hover:bg-slate-100 dark:text-slate-900 rounded-2xl text-xs font-bold transition-all cursor-pointer shadow-sm">
                    Upload New Image
                  </button>
                  <button type="button" onclick="clearProfileAvatar()" class="px-4 py-2.5 bg-rose-50 text-rose-600 dark:bg-rose-955/20 dark:text-rose-400 border border-rose-200/20 rounded-2xl text-xs font-bold transition-all cursor-pointer">
                    Remove
                  </button>
                </div>
                <p class="text-[10px] text-slate-400 dark:text-zinc-500 font-medium">Supports JPG, PNG, WEBP. Max file size: 2MB.</p>
                <input 
                  type="file" 
                  id="my-profile-avatar-file" 
                  accept="image/png, image/jpeg, image/webp" 
                  class="hidden" 
                  onchange="handleAvatarUpload(this)"
                />
                <input 
                  type="hidden" 
                  name="avatar" 
                  id="my-profile-avatar-input" 
                  value="<%= (locals.user && locals.user.avatar) || '' %>"
                />
              </div>
            </div>

            <!-- Name & Email -->
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              <div>
                <label class="text-[10px] font-extrabold text-slate-400 dark:text-zinc-555 uppercase tracking-wider mb-2 block">Full Name</label>
                <input 
                  type="text" 
                  name="name" 
                  value="<%= (locals.user && locals.user.name) || '' %>" 
                  required
                  class="w-full bg-slate-50 dark:bg-brand-darkBg border border-slate-200 dark:border-brand-darkBorder rounded-xl px-4 py-2.5 text-sm text-slate-800 dark:text-zinc-200 focus:outline-none focus:border-brand-orange transition-all"
                />
              </div>
              
              <div>
                <label class="text-[10px] font-extrabold text-slate-400 dark:text-zinc-555 uppercase tracking-wider mb-2 block">Email Address</label>
                <input 
                  type="email" 
                  name="email" 
                  value="<%= (locals.user && locals.user.email) || '' %>" 
                  required
                  class="w-full bg-slate-50 dark:bg-brand-darkBg border border-slate-200 dark:border-brand-darkBorder rounded-xl px-4 py-2.5 text-sm text-slate-800 dark:text-zinc-200 focus:outline-none focus:border-brand-orange transition-all"
                />
              </div>
            </div>

            <!-- Phone & Role -->
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              <div>
                <label class="text-[10px] font-extrabold text-slate-400 dark:text-zinc-555 uppercase tracking-wider mb-2 block">Phone Number</label>
                <input 
                  type="text" 
                  name="phone" 
                  value="<%= (locals.user && locals.user.phone) || '' %>" 
                  class="w-full bg-slate-50 dark:bg-brand-darkBg border border-slate-200 dark:border-brand-darkBorder rounded-xl px-4 py-2.5 text-sm text-slate-800 dark:text-zinc-200 focus:outline-none focus:border-brand-orange transition-all"
                  placeholder="e.g. +1 (555) 000-0000"
                />
              </div>
              
              <div>
                <label class="text-[10px] font-extrabold text-slate-400 dark:text-zinc-555 uppercase tracking-wider mb-2 block">Role</label>
                <input 
                  type="text" 
                  value="<%= (locals.user && locals.user.role) || '' %>" 
                  readonly
                  disabled
                  class="w-full bg-slate-100 dark:bg-brand-darkBg/60 border border-slate-200 dark:border-brand-darkBorder rounded-xl px-4 py-2.5 text-sm text-slate-450 dark:text-zinc-550 cursor-not-allowed select-none"
                />
                <p class="text-[10px] text-slate-400 dark:text-zinc-500 mt-1">Access role cannot be changed manually by standard users.</p>
              </div>
            </div>
          </div>
        </form>
      </section>

      <!-- Panel A: Dealership Profile -->
      <section id="panel-dealership-profile" class="settings-panel hidden bg-white dark:bg-brand-darkCard border border-slate-200/60 dark:border-brand-darkBorder rounded-3xl shadow-sm overflow-hidden">
        <form id="form-dealership-profile" action="/settings/profile" method="POST">
          <div class="px-6 py-4 border-b border-slate-100 dark:border-brand-darkBorder flex items-center justify-between bg-slate-50/50 dark:bg-brand-darkBg/50">
            <div class="flex items-center gap-3">
              <i data-lucide="building" class="w-5 h-5 text-brand-orange"></i>
              <div>
                <h3 class="font-bold text-base text-slate-900 dark:text-white">Dealership Profile</h3>
                <p class="text-xs text-slate-400 dark:text-zinc-500">Update your dealership's public identity and operation details.</p>
              </div>
            </div>
            <button type="submit" class="px-4 py-2 rounded-2xl text-xs font-bold bg-brand-orange hover:bg-orange-600 text-white cursor-pointer transition-all">
              Save Changes
            </button>
          </div>

          <div class="p-6 space-y-6">
            <!-- Dealership Name & Location -->
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              <div>
                <label class="text-[10px] font-extrabold text-slate-400 dark:text-zinc-500 uppercase tracking-wider mb-2 block">Dealership Name</label>
                <input 
                  type="text" 
                  name="dealershipName" 
                  value="<%= settings.dealershipName || '' %>" 
                  required
                  class="w-full bg-slate-50 dark:bg-brand-darkBg border border-slate-200 dark:border-brand-darkBorder rounded-xl px-4 py-2.5 text-sm text-slate-800 dark:text-zinc-200 focus:outline-none focus:border-brand-orange transition-all"
                />
              </div>
              
              <div>
                <label class="text-[10px] font-extrabold text-slate-400 dark:text-zinc-500 uppercase tracking-wider mb-2 block">Location</label>
                <div class="relative">
                  <div class="absolute inset-y-0 left-4 flex items-center text-slate-400"><i data-lucide="map-pin" class="w-4 h-4"></i></div>
                  <input 
                    type="text" 
                    name="dealershipLocation" 
                    value="<%= settings.dealershipLocation || '' %>" 
                    required
                    class="w-full pl-10 pr-4 py-2.5 bg-slate-50 dark:bg-brand-darkBg border border-slate-200 dark:border-brand-darkBorder rounded-xl text-sm text-slate-800 dark:text-zinc-200 focus:outline-none focus:border-brand-orange transition-all"
                  />
                </div>
              </div>
            </div>

            <!-- Phone & Email -->
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              <div>
                <label class="text-[10px] font-extrabold text-slate-400 dark:text-zinc-500 uppercase tracking-wider mb-2 block">Phone Number</label>
                <input 
                  type="text" 
                  name="dealershipPhone" 
                  value="<%= settings.dealershipPhone || '' %>" 
                  class="w-full bg-slate-50 dark:bg-brand-darkBg border border-slate-200 dark:border-brand-darkBorder rounded-xl px-4 py-2.5 text-sm text-slate-800 dark:text-zinc-200 focus:outline-none focus:border-brand-orange transition-all"
                />
              </div>
              
              <div>
                <label class="text-[10px] font-extrabold text-slate-400 dark:text-zinc-500 uppercase tracking-wider mb-2 block">Email Address</label>
                <input 
                  type="email" 
                  name="dealershipEmail" 
                  value="<%= settings.dealershipEmail || '' %>" 
                  class="w-full bg-slate-50 dark:bg-brand-darkBg border border-slate-200 dark:border-brand-darkBorder rounded-xl px-4 py-2.5 text-sm text-slate-800 dark:text-zinc-200 focus:outline-none focus:border-brand-orange transition-all"
                />
              </div>
            </div>

            <!-- Operating Hours -->
            <div>
              <label class="text-[10px] font-extrabold text-slate-400 dark:text-zinc-500 uppercase tracking-wider mb-2 block">Operating Hours</label>
              <div class="space-y-3">
                <% 
                  const defaultHours = [
                    { days: 'Monday - Friday', hours: '09:00 AM - 07:00 PM', status: 'open' },
                    { days: 'Saturday', hours: '10:00 AM - 05:00 PM', status: 'open' },
                    { days: 'Sunday', hours: 'Closed', status: 'closed' }
                  ];
                  const hoursList = (settings.hours && settings.hours.length > 0) ? settings.hours : defaultHours;
                %>
                <% hoursList.forEach((hr, index) => { %>
                  <div class="flex items-center gap-3 bg-slate-50 dark:bg-brand-darkBg border border-slate-100 dark:border-brand-darkBorder rounded-xl p-3">
                    <div class="flex-1">
                      <input 
                        type="text" 
                        name="hours[<%= index %>][days]" 
                        value="<%= hr.days %>" 
                        class="w-full bg-transparent border-none text-xs font-semibold text-slate-700 dark:text-zinc-300 focus:outline-none focus:ring-0"
                        readonly
                      />
                    </div>
                    <div class="flex-1">
                      <input 
                        type="text" 
                        name="hours[<%= index %>][hours]" 
                        value="<%= hr.hours %>" 
                        placeholder="e.g., 09:00 AM - 07:00 PM"
                        class="w-full bg-white dark:bg-brand-darkCard border border-slate-200 dark:border-brand-darkBorder rounded-lg px-3 py-2 text-xs text-slate-800 dark:text-zinc-200 focus:outline-none focus:border-brand-orange transition-all"
                      />
                    </div>
                    <div class="flex items-center gap-2">
                      <label class="flex items-center gap-2 cursor-pointer">
                        <input 
                          type="radio" 
                          name="hours[<%= index %>][status]" 
                          value="open" 
                          <%= hr.status === 'open' ? 'checked' : '' %>
                          class="w-4 h-4 text-brand-orange focus:ring-brand-orange"
                        />
                        <span class="text-xs font-semibold text-slate-700 dark:text-zinc-300">Open</span>
                      </label>
                      <label class="flex items-center gap-2 cursor-pointer">
                        <input 
                          type="radio" 
                          name="hours[<%= index %>][status]" 
                          value="closed" 
                          <%= hr.status === 'closed' ? 'checked' : '' %>
                          class="w-4 h-4 text-brand-orange focus:ring-brand-orange"
                        />
                        <span class="text-xs font-semibold text-slate-700 dark:text-zinc-300">Closed</span>
                      </label>
                    </div>
                  </div>
                <% }) %>
              </div>
            </div>
          </div>
        </form>
      </section>

      <!-- Panel B: User Management -->
      <section id="panel-user-management" class="settings-panel hidden bg-white dark:bg-brand-darkCard border border-slate-200/60 dark:border-brand-darkBorder rounded-3xl shadow-sm overflow-hidden">
        <div class="px-6 py-4 border-b border-slate-100 dark:border-brand-darkBorder flex items-center justify-between bg-slate-50/50 dark:bg-brand-darkBg/50">
          <div class="flex items-center gap-3">
            <i data-lucide="users" class="w-5 h-5 text-brand-orange"></i>
            <div>
              <h3 class="font-bold text-base text-slate-900 dark:text-white">User Management</h3>
              <p class="text-xs text-slate-400 dark:text-zinc-500">Manage team access and role-specific permissions.</p>
            </div>
          </div>
          <button onclick="openInviteModal()" class="px-4 py-2 rounded-2xl text-xs font-bold bg-brand-orange hover:bg-orange-600 text-white cursor-pointer transition-all flex items-center gap-2">
            <i data-lucide="user-plus" class="w-4 h-4"></i>
            Invite Member
          </button>
        </div>

        <div class="p-6 flex flex-col xl:flex-row gap-6">
          <!-- Left: Users Table -->
          <div class="flex-1 overflow-x-auto">
            <div class="flex items-center justify-between mb-4">
              <button id="select-users-btn" class="flex items-center gap-2 px-3 py-1.5 rounded-xl text-xs font-bold border border-slate-200 dark:border-brand-darkBorder hover:bg-slate-50 dark:hover:bg-brand-darkBg text-slate-700 dark:text-zinc-300 transition-all cursor-pointer">
                <i data-lucide="check-square" class="w-4 h-4"></i>
                <span>Select Users</span>
              </button>
              <div id="bulk-actions-container" class="hidden flex items-center gap-2">
                <button id="cancel-selection-btn" class="flex items-center gap-1.5 bg-slate-50 hover:bg-slate-100 border border-slate-200 dark:bg-brand-darkBg dark:border-brand-darkBorder dark:hover:bg-zinc-800 rounded-full px-3.5 py-1.5 text-[10px] font-bold text-slate-600 dark:text-zinc-400 cursor-pointer transition-all">
                  <i data-lucide="x" class="w-3.5 h-3.5"></i>
                  <span>Cancel</span>
                </button>
                <div class="flex items-center gap-2">
                  <input type="checkbox" id="select-all-users" class="w-4 h-4 rounded border-slate-300 dark:border-brand-darkBorder text-brand-orange focus:ring-brand-orange bg-slate-50 dark:bg-brand-darkBg cursor-pointer accent-brand-orange" />
                  <label for="select-all-users" class="text-xs font-bold text-slate-500 dark:text-zinc-400 cursor-pointer">Select All</label>
                </div>
                <button id="bulk-delete-users-btn" class="hidden flex items-center gap-1.5 bg-rose-50 hover:bg-rose-100 border border-rose-200 dark:bg-rose-955/20 dark:border-rose-900/50 dark:hover:bg-rose-950/30 rounded-full px-3.5 py-1.5 text-[10px] font-bold text-rose-600 dark:text-rose-400 cursor-pointer transition-all">
                  <i data-lucide="trash-2" class="w-3.5 h-3.5"></i>
                  <span>Delete Selected</span>
                </button>
              </div>
            </div>
            <table class="w-full text-left border-collapse text-sm">
              <thead>
                <tr class="border-b border-slate-100 dark:border-brand-darkBorder text-[10px] font-extrabold text-slate-400 dark:text-zinc-500 uppercase tracking-wider pb-3">
                  <th class="py-3">Member</th>
                  <th class="py-3">Role</th>
                  <th class="py-3">Status</th>
                  <th class="py-3 text-right">Action</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-50 dark:divide-brand-darkBorder text-slate-700 dark:text-zinc-300">
                <% (users || []).forEach(usr => { %>
                  <tr class="hover:bg-slate-50/20 dark:hover:bg-brand-darkBg/20 user-row" data-user-id="<%= usr._id %>">
                    <td class="py-4 flex items-center gap-3">
                      <% if (usr.avatar) { %>
                        <img src="<%= usr.avatar %>" alt="Avatar" class="w-8 h-8 rounded-full object-cover shrink-0 border border-slate-200 dark:border-brand-darkBorder shadow-sm" />
                      <% } else { %>
                        <div class="w-8 h-8 rounded-full flex items-center justify-center font-bold text-xs <%= usr.avatarBg %> shrink-0">
                          <%= usr.initials %>
                        </div>
                      <% } %>
                      <div>
                        <h4 class="font-bold text-slate-800 dark:text-zinc-200"><%= usr.name %></h4>
                        <span class="text-xs text-slate-400 dark:text-zinc-500"><%= usr.email %></span>
                      </div>
                    </td>
                    <td class="py-4">
                      <span class="px-2 py-0.5 text-xs font-bold rounded bg-slate-100 text-slate-700 dark:bg-brand-darkBg dark:text-zinc-400"><%= usr.role %></span>
                    </td>
                    <td class="py-4">
                      <span class="flex items-center gap-1.5 text-xs font-semibold">
                        <span class="w-2 h-2 rounded-full <%= usr.status === 'Active' ? 'bg-emerald-500' : 'bg-rose-500' %>"></span>
                        <%= usr.status %>
                      </span>
                    </td>
                    <td class="py-4 text-right relative pr-6">
                      <button onclick="toggleUserDropdown(event, '<%= usr._id %>')" class="text-slate-400 hover:text-slate-600 dark:hover:text-white cursor-pointer focus:outline-none">
                        <i data-lucide="more-vertical" class="w-4 h-4"></i>
                      </button>
                      
                      <!-- Dropdown Menu -->
                      <div id="dropdown-<%= usr._id %>" class="user-dropdown hidden absolute right-6 top-10 w-44 bg-white dark:bg-brand-darkCard border border-slate-200 dark:border-brand-darkBorder rounded-2xl shadow-xl z-30 p-2 text-left font-semibold font-sans">
                        <button onclick="showUserDetailsPanel('<%= usr._id %>', '<%= usr.name.replace(/'/g, '\\\'') %>', '<%= usr.email %>', '<%= (usr.phone || '').replace(/'/g, '\\\'') %>', '<%= usr.role %>', '<%= usr.status %>', '<%= usr.avatar || '' %>')" class="w-full flex items-center gap-2 px-3 py-2 rounded-xl text-xs text-slate-700 dark:text-zinc-300 hover:bg-slate-50 dark:hover:bg-brand-darkBg cursor-pointer">
                          <i data-lucide="eye" class="w-3.5 h-3.5 text-slate-400"></i> View Details
                        </button>
                        <button onclick="showEditUserPanel('<%= usr._id %>', '<%= usr.name.replace(/'/g, '\\\'') %>', '<%= (usr.phone || '').replace(/'/g, '\\\'') %>')" class="w-full flex items-center gap-2 px-3 py-2 rounded-xl text-xs text-slate-700 dark:text-zinc-300 hover:bg-slate-50 dark:hover:bg-brand-darkBg cursor-pointer">
                          <i data-lucide="edit" class="w-3.5 h-3.5 text-slate-400"></i> Edit Profile
                        </button>
                        <button onclick="changeRole('<%= usr._id %>', '<%= usr.name.replace(/'/g, '\\\'') %>', '<%= usr.role %>')" class="w-full flex items-center gap-2 px-3 py-2 rounded-xl text-xs text-slate-700 dark:text-zinc-300 hover:bg-slate-50 dark:hover:bg-brand-darkBg cursor-pointer">
                          <i data-lucide="shield" class="w-3.5 h-3.5 text-slate-400"></i> Change Role
                        </button>
                        <button onclick="toggleStatus('<%= usr._id %>', '<%= usr.name.replace(/'/g, '\\\'') %>', '<%= usr.status %>')" class="w-full flex items-center gap-2 px-3 py-2 rounded-xl text-xs text-slate-700 dark:text-zinc-300 hover:bg-slate-50 dark:hover:bg-brand-darkBg cursor-pointer">
                          <i data-lucide="<%= usr.status === 'Active' ? 'user-minus' : 'user-check' %>" class="w-3.5 h-3.5 text-slate-400"></i>
                          <span><%= usr.status === 'Active' ? 'Deactivate' : 'Activate' %></span>
                        </button>
                        <hr class="border-slate-100 dark:border-brand-darkBorder my-1" />
                        <button onclick="deleteUser('<%= usr._id %>', '<%= usr.name.replace(/'/g, '\\\'') %>')" class="w-full flex items-center gap-2 px-3 py-2 rounded-xl text-xs text-rose-500 hover:bg-rose-50 dark:hover:bg-rose-950/20 cursor-pointer">
                          <i data-lucide="trash-2" class="w-3.5 h-3.5"></i> Delete Member
                        </button>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
          
          <!-- Right: User Details Panel -->
          <div id="user-details-panel" class="hidden w-80 shrink-0 bg-slate-50 dark:bg-brand-darkBg border border-slate-200 dark:border-brand-darkBorder rounded-2xl p-4 order-last">
            <div class="flex items-center justify-between mb-4">
              <h4 class="font-bold text-sm text-slate-900 dark:text-white">User Details</h4>
              <button onclick="closeUserDetailsPanel()" class="text-slate-400 hover:text-slate-600 dark:hover:text-white cursor-pointer">
                <i data-lucide="x" class="w-4 h-4"></i>
              </button>
            </div>
            <div id="user-details-content" class="space-y-3">
              <!-- Content will be dynamically populated -->
            </div>
          </div>
        </div>
      </section>

      <!-- Panel C: CRM Configurations -->
      <section id="panel-crm-configurations" class="settings-panel hidden bg-white dark:bg-brand-darkCard border border-slate-200/60 dark:border-brand-darkBorder rounded-3xl shadow-sm overflow-hidden">
        <form id="form-crm-config" action="/settings/crm-config" method="POST">
          <div class="px-6 py-4 border-b border-slate-100 dark:border-brand-darkBorder flex items-center justify-between bg-slate-50/50 dark:bg-brand-darkBg/50">
            <div class="flex items-center gap-3">
              <i data-lucide="sliders" class="w-5 h-5 text-brand-orange"></i>
              <div>
                <h3 class="font-bold text-base text-slate-900 dark:text-white">CRM Configurations</h3>
                <p class="text-xs text-slate-400 dark:text-zinc-500">Modify global CRM workflows, pipeline settings, and custom configurations.</p>
              </div>
            </div>
            <button type="submit" class="px-4 py-2 rounded-2xl text-xs font-bold bg-brand-orange hover:bg-orange-600 text-white cursor-pointer transition-all">
              Save Changes
            </button>
          </div>

          <div class="p-6 space-y-6">
            <!-- Pipeline Stages Configuration -->
            <div>
              <label class="text-[10px] font-extrabold text-slate-400 dark:text-zinc-555 uppercase tracking-wider mb-2 block">Pipeline Stages / Lead Statuses (comma-separated)</label>
              <input 
                type="text" 
                name="pipelineStages" 
                value="<%= (settings.crmConfig && settings.crmConfig.pipelineStages) ? settings.crmConfig.pipelineStages.join(', ') : 'New, Contacted, Interested, Test Ride Booked, Negotiation, Sold, Lost' %>"
                class="w-full bg-slate-50 dark:bg-brand-darkBg border border-slate-200 dark:border-brand-darkBorder rounded-xl px-4 py-2.5 text-sm text-slate-800 dark:text-zinc-200 focus:outline-none focus:border-brand-orange transition-all"
                placeholder="e.g. New, Contacted, Interested, Test Ride Booked, Negotiation, Sold, Lost"
              />
              <p class="text-[11px] text-slate-400 dark:text-zinc-500 mt-1">Specify custom stages. This updates the Kanban board columns and lead statuses.</p>
            </div>

            <!-- Default Lead Status -->
            <div>
              <label class="text-[10px] font-extrabold text-slate-400 dark:text-zinc-555 uppercase tracking-wider mb-2 block">Default Lead Status</label>
              <select 
                name="defaultLeadStatus" 
                class="w-full bg-slate-50 dark:bg-brand-darkBg border border-slate-200 dark:border-brand-darkBorder rounded-xl px-4 py-2.5 text-sm text-slate-800 dark:text-zinc-200 focus:outline-none focus:border-brand-orange transition-all"
              >
                <% 
                  const defaultStages = ['New', 'Contacted', 'Interested', 'Test Ride Booked', 'Negotiation', 'Sold', 'Lost'];
                  const currentStages = (settings.crmConfig && settings.crmConfig.pipelineStages && settings.crmConfig.pipelineStages.length > 0) 
                    ? settings.crmConfig.pipelineStages 
                    : defaultStages;
                  currentStages.forEach(stg => {
                %>
                  <option value="<%= stg %>" <%= (settings.crmConfig && settings.crmConfig.defaultLeadStatus === stg) ? 'selected' : '' %>><%= stg %></option>
                <% }) %>
              </select>
            </div>

            <!-- Lead Assignment Method -->
            <div>
              <label class="text-[10px] font-extrabold text-slate-400 dark:text-zinc-555 uppercase tracking-wider mb-2 block">Lead Assignment Method</label>
              <select 
                name="leadAssignmentMethod" 
                class="w-full bg-slate-50 dark:bg-brand-darkBg border border-slate-200 dark:border-brand-darkBorder rounded-xl px-4 py-2.5 text-sm text-slate-800 dark:text-zinc-200 focus:outline-none focus:border-brand-orange transition-all"
              >
                <option value="Round Robin" <%= (settings.crmConfig && settings.crmConfig.leadAssignmentMethod === 'Round Robin') ? 'selected' : '' %>>Round Robin (Equal Distribution)</option>
                <option value="Manual" <%= (settings.crmConfig && settings.crmConfig.leadAssignmentMethod === 'Manual') ? 'selected' : '' %>>Manual (Assigned by Admin/Manager)</option>
                <option value="Load Balanced" <%= (settings.crmConfig && settings.crmConfig.leadAssignmentMethod === 'Load Balanced') ? 'selected' : '' %>>Load Balanced (Based on Active Lead Count)</option>
              </select>
            </div>

            <!-- Auto Assign Leads -->
            <div class="flex items-center justify-between border-t border-slate-50 dark:border-brand-darkBorder pt-4">
              <div>
                <h4 class="font-bold text-sm text-slate-800 dark:text-zinc-200">Auto-Assign Leads</h4>
                <p class="text-xs text-slate-400 dark:text-zinc-500">Automatically assign new leads to available sales executives.</p>
              </div>
              <div class="flex items-center gap-2">
                <label class="flex items-center gap-2 cursor-pointer">
                  <input 
                    type="radio" 
                    name="autoAssignLeads" 
                    value="true" 
                    <%= (settings.crmConfig && settings.crmConfig.autoAssignLeads) ? 'checked' : '' %>
                    class="w-4 h-4 text-brand-orange focus:ring-brand-orange"
                  />
                  <span class="text-xs font-semibold text-slate-700 dark:text-zinc-300">Yes</span>
                </label>
                <label class="flex items-center gap-2 cursor-pointer">
                  <input 
                    type="radio" 
                    name="autoAssignLeads" 
                    value="false" 
                    <%= (!settings.crmConfig || !settings.crmConfig.autoAssignLeads) ? 'checked' : '' %>
                    class="w-4 h-4 text-brand-orange focus:ring-brand-orange"
                  />
                  <span class="text-xs font-semibold text-slate-700 dark:text-zinc-300">No</span>
                </label>
              </div>
            </div>

            <!-- Follow-up Reminder Days -->
            <div class="border-t border-slate-50 dark:border-brand-darkBorder pt-4">
              <label class="text-[10px] font-extrabold text-slate-400 dark:text-zinc-555 uppercase tracking-wider mb-2 block">Follow-up Reminder Days</label>
              <input 
                type="number" 
                name="followUpReminderDays" 
                value="<%= (settings.crmConfig && settings.crmConfig.followUpReminderDays) || 3 %>" 
                min="1"
                max="30"
                class="w-full bg-slate-50 dark:bg-brand-darkBg border border-slate-200 dark:border-brand-darkBorder rounded-xl px-4 py-2.5 text-sm text-slate-800 dark:text-zinc-200 focus:outline-none focus:border-brand-orange transition-all"
              />
            </div>
          </div>
        </form>
      </section>

      <!-- Panel D: Notification Preferences -->
      <section id="panel-notifications" class="settings-panel hidden bg-white dark:bg-brand-darkCard border border-slate-200/60 dark:border-brand-darkBorder rounded-3xl shadow-sm overflow-hidden">
        <form id="form-notifications" action="/settings/notifications" method="POST">
          <input type="hidden" name="email" id="input-notifications-email" value="<%= (settings.notifications && settings.notifications.email) ? 'true' : 'false' %>">
          <input type="hidden" name="sms" id="input-notifications-sms" value="<%= (settings.notifications && settings.notifications.sms) ? 'true' : 'false' %>">
          <input type="hidden" name="pushNotifications" id="input-notifications-pushNotifications" value="<%= (settings.notifications && settings.notifications.pushNotifications) ? 'true' : 'false' %>">
          <input type="hidden" name="newLeads" id="input-notifications-newLeads" value="<%= (settings.notifications && settings.notifications.newLeads) ? 'true' : 'false' %>">
          <input type="hidden" name="followUpReminders" id="input-notifications-followUpReminders" value="<%= (settings.notifications && settings.notifications.followUpReminders) ? 'true' : 'false' %>">
          <input type="hidden" name="testRideAlerts" id="input-notifications-testRideAlerts" value="<%= (settings.notifications && settings.notifications.testRideAlerts) ? 'true' : 'false' %>">
          <input type="hidden" name="systemNotifications" id="input-notifications-systemNotifications" value="<%= (settings.notifications && settings.notifications.systemNotifications) ? 'true' : 'false' %>">

          <div class="px-6 py-4 border-b border-slate-100 dark:border-brand-darkBorder flex items-center justify-between bg-slate-50/50 dark:bg-brand-darkBg/50">
            <div class="flex items-center gap-3">
              <i data-lucide="bell" class="w-5 h-5 text-brand-orange"></i>
              <div>
                <h3 class="font-bold text-base text-slate-900 dark:text-white">Notification Preferences</h3>
                <p class="text-xs text-slate-400 dark:text-zinc-500">Configure email, SMS, and real-time alerts.</p>
              </div>
            </div>
            <button type="submit" class="px-4 py-2 rounded-2xl text-xs font-bold bg-brand-orange hover:bg-orange-600 text-white cursor-pointer transition-all">
              Save Changes
            </button>
          </div>

          <div class="p-6 space-y-6">
            
            <!-- Channels Section -->
            <div class="space-y-4">
              <h4 class="text-[10px] font-extrabold text-slate-400 dark:text-zinc-555 uppercase tracking-wider block">Notification Channels</h4>
              
              <!-- Email Notifications -->
              <div class="flex items-center justify-between gap-4 border-b border-slate-50 dark:border-brand-darkBorder pb-4">
                <div class="flex items-start gap-3">
                  <div class="w-8 h-8 rounded-lg bg-orange-50/55 dark:bg-brand-darkBg flex items-center justify-center text-brand-orange shrink-0"><i data-lucide="mail" class="w-4.5 h-4.5"></i></div>
                  <div>
                    <h4 class="font-bold text-sm text-slate-800 dark:text-zinc-200">Email Notifications</h4>
                    <p class="text-xs text-slate-400 dark:text-zinc-500">Receive summary of daily leads and pending tasks.</p>
                  </div>
                </div>
                <div class="flex items-center gap-2">
                  <span id="text-notifications-email" class="text-xs font-bold text-slate-500 dark:text-zinc-400"><%= (settings.notifications && settings.notifications.email) ? 'Enabled' : 'Disabled' %></span>
                  <button 
                    type="button" 
                    onclick="toggleSwitch('notifications-email')"
                    id="btn-notifications-email"
                    class="w-10 h-6 rounded-full p-1 cursor-pointer transition-colors <%= (settings.notifications && settings.notifications.email) ? 'bg-brand-orange' : 'bg-slate-200 dark:bg-zinc-700' %>"
                  >
                    <div id="dot-notifications-email" class="w-4 h-4 bg-white rounded-full transition-transform <%= (settings.notifications && settings.notifications.email) ? 'translate-x-4' : 'translate-x-0' %>"></div>
                  </button>
                </div>
              </div>

              <!-- SMS Notifications -->
              <div class="flex items-center justify-between gap-4 border-b border-slate-50 dark:border-brand-darkBorder pb-4">
                <div class="flex items-start gap-3">
                  <div class="w-8 h-8 rounded-lg bg-orange-50/55 dark:bg-brand-darkBg flex items-center justify-center text-brand-orange shrink-0"><i data-lucide="message-square" class="w-4.5 h-4.5"></i></div>
                  <div>
                    <h4 class="font-bold text-sm text-slate-800 dark:text-zinc-200">SMS Notifications</h4>
                    <p class="text-xs text-slate-400 dark:text-zinc-500">Instant alerts for urgent updates directly on your phone.</p>
                  </div>
                </div>
                <div class="flex items-center gap-2">
                  <span id="text-notifications-sms" class="text-xs font-bold text-slate-500 dark:text-zinc-400"><%= (settings.notifications && settings.notifications.sms) ? 'Enabled' : 'Disabled' %></span>
                  <button 
                    type="button" 
                    onclick="toggleSwitch('notifications-sms')"
                    id="btn-notifications-sms"
                    class="w-10 h-6 rounded-full p-1 cursor-pointer transition-colors <%= (settings.notifications && settings.notifications.sms) ? 'bg-brand-orange' : 'bg-slate-200 dark:bg-zinc-700' %>"
                  >
                    <div id="dot-notifications-sms" class="w-4 h-4 bg-white rounded-full transition-transform <%= (settings.notifications && settings.notifications.sms) ? 'translate-x-4' : 'translate-x-0' %>"></div>
                  </button>
                </div>
              </div>

              <!-- Push Notifications -->
              <div class="flex items-center justify-between gap-4">
                <div class="flex items-start gap-3">
                  <div class="w-8 h-8 rounded-lg bg-orange-50/55 dark:bg-brand-darkBg flex items-center justify-center text-brand-orange shrink-0"><i data-lucide="bell-ring" class="w-4.5 h-4.5"></i></div>
                  <div>
                    <h4 class="font-bold text-sm text-slate-800 dark:text-zinc-200">Push Notifications</h4>
                    <p class="text-xs text-slate-400 dark:text-zinc-500">Real-time alerts displayed inside the web browser.</p>
                  </div>
                </div>
                <div class="flex items-center gap-2">
                  <span id="text-notifications-pushNotifications" class="text-xs font-bold text-slate-500 dark:text-zinc-400"><%= (settings.notifications && settings.notifications.pushNotifications) ? 'Enabled' : 'Disabled' %></span>
                  <button 
                    type="button" 
                    onclick="toggleSwitch('notifications-pushNotifications')"
                    id="btn-notifications-pushNotifications"
                    class="w-10 h-6 rounded-full p-1 cursor-pointer transition-colors <%= (settings.notifications && settings.notifications.pushNotifications) ? 'bg-brand-orange' : 'bg-slate-200 dark:bg-zinc-700' %>"
                  >
                    <div id="dot-notifications-pushNotifications" class="w-4 h-4 bg-white rounded-full transition-transform <%= (settings.notifications && settings.notifications.pushNotifications) ? 'translate-x-4' : 'translate-x-0' %>"></div>
                  </button>
                </div>
              </div>
            </div>

            <!-- Alert Categories Section -->
            <div class="space-y-4 pt-4 border-t border-slate-100 dark:border-brand-darkBorder">
              <h4 class="text-[10px] font-extrabold text-slate-400 dark:text-zinc-555 uppercase tracking-wider block">Alert Events (Real-Time Alerts)</h4>

              <!-- New Leads Alert -->
              <div class="flex items-center justify-between gap-4 border-b border-slate-50 dark:border-brand-darkBorder pb-4">
                <div class="flex items-start gap-3">
                  <div class="w-8 h-8 rounded-lg bg-orange-50/55 dark:bg-brand-darkBg flex items-center justify-center text-brand-orange shrink-0"><i data-lucide="user-plus" class="w-4.5 h-4.5"></i></div>
                  <div>
                    <h4 class="font-bold text-sm text-slate-800 dark:text-zinc-200">New Leads</h4>
                    <p class="text-xs text-slate-400 dark:text-zinc-500">Get notified immediately when a new lead enters the system.</p>
                  </div>
                </div>
                <div class="flex items-center gap-2">
                  <span id="text-notifications-newLeads" class="text-xs font-bold text-slate-500 dark:text-zinc-400"><%= (settings.notifications && settings.notifications.newLeads) ? 'Enabled' : 'Disabled' %></span>
                  <button 
                    type="button" 
                    onclick="toggleSwitch('notifications-newLeads')"
                    id="btn-notifications-newLeads"
                    class="w-10 h-6 rounded-full p-1 cursor-pointer transition-colors <%= (settings.notifications && settings.notifications.newLeads) ? 'bg-brand-orange' : 'bg-slate-200 dark:bg-zinc-700' %>"
                  >
                    <div id="dot-notifications-newLeads" class="w-4 h-4 bg-white rounded-full transition-transform <%= (settings.notifications && settings.notifications.newLeads) ? 'translate-x-4' : 'translate-x-0' %>"></div>
                  </button>
                </div>
              </div>

              <!-- Follow-up Reminders Alert -->
              <div class="flex items-center justify-between gap-4 border-b border-slate-50 dark:border-brand-darkBorder pb-4">
                <div class="flex items-start gap-3">
                  <div class="w-8 h-8 rounded-lg bg-orange-50/55 dark:bg-brand-darkBg flex items-center justify-center text-brand-orange shrink-0"><i data-lucide="clock" class="w-4.5 h-4.5"></i></div>
                  <div>
                    <h4 class="font-bold text-sm text-slate-800 dark:text-zinc-200">Follow-up Reminders</h4>
                    <p class="text-xs text-slate-400 dark:text-zinc-500">Alerts for scheduled follow-ups and customer touchpoints.</p>
                  </div>
                </div>
                <div class="flex items-center gap-2">
                  <span id="text-notifications-followUpReminders" class="text-xs font-bold text-slate-500 dark:text-zinc-400"><%= (settings.notifications && settings.notifications.followUpReminders) ? 'Enabled' : 'Disabled' %></span>
                  <button 
                    type="button" 
                    onclick="toggleSwitch('notifications-followUpReminders')"
                    id="btn-notifications-followUpReminders"
                    class="w-10 h-6 rounded-full p-1 cursor-pointer transition-colors <%= (settings.notifications && settings.notifications.followUpReminders) ? 'bg-brand-orange' : 'bg-slate-200 dark:bg-zinc-700' %>"
                  >
                    <div id="dot-notifications-followUpReminders" class="w-4 h-4 bg-white rounded-full transition-transform <%= (settings.notifications && settings.notifications.followUpReminders) ? 'translate-x-4' : 'translate-x-0' %>"></div>
                  </button>
                </div>
              </div>

              <!-- Test Ride Alerts -->
              <div class="flex items-center justify-between gap-4 border-b border-slate-50 dark:border-brand-darkBorder pb-4">
                <div class="flex items-start gap-3">
                  <div class="w-8 h-8 rounded-lg bg-orange-50/55 dark:bg-brand-darkBg flex items-center justify-center text-brand-orange shrink-0"><i data-lucide="bike" class="w-4.5 h-4.5"></i></div>
                  <div>
                    <h4 class="font-bold text-sm text-slate-800 dark:text-zinc-200">Test Ride Alerts</h4>
                    <p class="text-xs text-slate-400 dark:text-zinc-500">Alerts when a test ride is booked, rescheduled, or cancelled.</p>
                  </div>
                </div>
                <div class="flex items-center gap-2">
                  <span id="text-notifications-testRideAlerts" class="text-xs font-bold text-slate-500 dark:text-zinc-400"><%= (settings.notifications && settings.notifications.testRideAlerts) ? 'Enabled' : 'Disabled' %></span>
                  <button 
                    type="button" 
                    onclick="toggleSwitch('notifications-testRideAlerts')"
                    id="btn-notifications-testRideAlerts"
                    class="w-10 h-6 rounded-full p-1 cursor-pointer transition-colors <%= (settings.notifications && settings.notifications.testRideAlerts) ? 'bg-brand-orange' : 'bg-slate-200 dark:bg-zinc-700' %>"
                  >
                    <div id="dot-notifications-testRideAlerts" class="w-4 h-4 bg-white rounded-full transition-transform <%= (settings.notifications && settings.notifications.testRideAlerts) ? 'translate-x-4' : 'translate-x-0' %>"></div>
                  </button>
                </div>
              </div>

              <!-- System Notifications Alert -->
              <div class="flex items-center justify-between gap-4">
                <div class="flex items-start gap-3">
                  <div class="w-8 h-8 rounded-lg bg-orange-50/55 dark:bg-brand-darkBg flex items-center justify-center text-brand-orange shrink-0"><i data-lucide="settings" class="w-4.5 h-4.5"></i></div>
                  <div>
                    <h4 class="font-bold text-sm text-slate-800 dark:text-zinc-200">System Notifications</h4>
                    <p class="text-xs text-slate-400 dark:text-zinc-500">Important system updates, backup status, and security alerts.</p>
                  </div>
                </div>
                <div class="flex items-center gap-2">
                  <span id="text-notifications-systemNotifications" class="text-xs font-bold text-slate-500 dark:text-zinc-400"><%= (settings.notifications && settings.notifications.systemNotifications) ? 'Enabled' : 'Disabled' %></span>
                  <button 
                    type="button" 
                    onclick="toggleSwitch('notifications-systemNotifications')"
                    id="btn-notifications-systemNotifications"
                    class="w-10 h-6 rounded-full p-1 cursor-pointer transition-colors <%= (settings.notifications && settings.notifications.systemNotifications) ? 'bg-brand-orange' : 'bg-slate-200 dark:bg-zinc-700' %>"
                  >
                    <div id="dot-notifications-systemNotifications" class="w-4 h-4 bg-white rounded-full transition-transform <%= (settings.notifications && settings.notifications.systemNotifications) ? 'translate-x-4' : 'translate-x-0' %>"></div>
                  </button>
                </div>
              </div>
            </div>

          </div>
        </form>
      </section>


      <!-- Panel E: Third-Party Integrations -->
      <section id="panel-integrations" class="settings-panel hidden bg-white dark:bg-brand-darkCard border border-slate-200/60 dark:border-brand-darkBorder rounded-3xl shadow-sm overflow-hidden">
        <form id="form-integrations" action="/settings/integrations" method="POST">
          <div class="px-6 py-4 border-b border-slate-100 dark:border-brand-darkBorder flex items-center justify-between bg-slate-50/50 dark:bg-brand-darkBg/50">
            <div class="flex items-center gap-3">
              <i data-lucide="link" class="w-5 h-5 text-brand-orange"></i>
              <div>
                <h3 class="font-bold text-base text-slate-900 dark:text-white">Third-Party Integrations</h3>
                <p class="text-xs text-slate-400 dark:text-zinc-500">Manage connections with external calendars, services, and APIs.</p>
              </div>
